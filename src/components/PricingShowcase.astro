---
import PageHeroBackground from './PageHeroBackground.astro'
import Spacer from './Spacer.astro'

interface Package {
  title: string
  description?: string
  price?: string
  period?: string
  customPriceLabel?: string
  ctaLabel?: string
  featured?: boolean
  features?: string[]
}
interface Props {
  badge?: string
  heading?: string
  highlightPhrase?: string
  subtitle?: string
  packages: Package[]
  showHeroBackground?: boolean
  calLink?: string
  calNamespace?: string
}
const {
  badge = 'Pricing',
  heading = 'Choose the best package for you',
  highlightPhrase = 'best package',
  subtitle = 'Transparent pricing. No hidden costs. Just results.',
  packages,
  showHeroBackground = false,
  calLink,
  calNamespace,
} = Astro.props as Props

// A package CTA labeled "Book a Call" opens the Cal.com popup; one containing
// "quote" opens the free-quote modal; everything else links to /contact.
function isBookACallLabel(label?: string) {
  return /book a call/i.test(label ?? '')
}
function isQuoteLabel(label?: string) {
  return /quote/i.test(label ?? '')
}

// Split the heading around the highlighted phrase so it can render in accent
// color while the rest stays default — natural wrap only, no forced <br>.
function splitHeading(text: string, phrase?: string) {
  if (!phrase) return [{ text, accent: false }]
  const idx = text.indexOf(phrase)
  if (idx === -1) return [{ text, accent: false }]
  return [
    { text: text.slice(0, idx), accent: false },
    { text: text.slice(idx, idx + phrase.length), accent: true },
    { text: text.slice(idx + phrase.length), accent: false },
  ].filter(part => part.text.length > 0)
}
const headingParts = splitHeading(heading, highlightPhrase)

// Needs a static lookup so Tailwind's build-time scanner can see the literal class.
const colsClass: Record<number, string> = {
  1: 'md:grid-cols-1',
  2: 'md:grid-cols-2',
  3: 'md:grid-cols-3',
  4: 'md:grid-cols-4',
}
const gridColsClass = colsClass[packages.length] ?? 'md:grid-cols-3'
---

<section>
  <div class="container md:border-x md:border-border-light md:px-0">
    <div class={`relative overflow-hidden ${showHeroBackground ? 'min-h-[300px] md:min-h-[400px] flex flex-col justify-center' : ''}`}>
      {showHeroBackground && <PageHeroBackground />}
      <div class="px-6 md:pl-[30px] md:pr-8 py-10 md:py-14">
        <span class="inline-block border border-border-light rounded-full text-xs font-normal px-3 py-1 text-text-muted mb-4">{badge}</span>
        <h2 class="text-4xl md:text-5xl font-bold text-text-white mb-3 tracking-tight max-w-[800px]">
          {headingParts.map(part => part.accent ? <span class="text-accent">{part.text}</span> : part.text)}
        </h2>
        {subtitle && <p class="text-text-muted text-lg">{subtitle}</p>}
      </div>
    </div>
  </div>

  {showHeroBackground && <Spacer borderTop borderBottom />}

  <div class="container md:border-x md:border-border-light md:px-0">
    <div class={`${showHeroBackground ? '' : 'border-t border-border-light'} py-10 md:py-14 px-6 md:px-8`}>
      <div class={`grid grid-cols-1 ${gridColsClass} gap-6`}>
        {packages.map(pkg => (
          <div class={`border p-8 flex flex-col bg-bg-1 transition-colors ${pkg.featured ? 'border-accent glow-accent' : 'border-border-light'}`}>
            <div class="flex items-center flex-wrap gap-2 mb-2">
              <h3 class="font-bold text-2xl text-text-white">{pkg.title}</h3>
              {pkg.featured && <span class="badge-accent whitespace-nowrap">Most Popular</span>}
            </div>

            {pkg.description && (
              <p class="text-text-muted text-base mb-6">{pkg.description}</p>
            )}

            {pkg.customPriceLabel ? (
              <div class="text-4xl font-black text-text-white mb-6 tracking-tight">{pkg.customPriceLabel}</div>
            ) : (
              <div class="flex items-baseline gap-1 mb-6 text-text-white">
                <span class="text-lg self-start mt-1">$</span>
                <span class="text-5xl font-bold tracking-tight">{pkg.price}</span>
                {pkg.period && <span class="text-text-muted text-sm">/{pkg.period.replace(/^\/+/, '')}</span>}
              </div>
            )}

            {(() => {
              const ctaClass = `group inline-flex items-center justify-center gap-2 rounded-btn px-5 py-3 font-semibold text-base transition-colors mb-8 w-full cursor-pointer ${
                pkg.featured
                  ? 'bg-accent-dark text-white hover:bg-accent-darker'
                  : 'border border-border-light text-text-white hover:bg-bg-2'
              }`
              const arrow = (
                <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )
              if (isQuoteLabel(pkg.ctaLabel)) {
                return (
                  <button type="button" data-open-quote-modal class={ctaClass}>
                    {pkg.ctaLabel ?? 'Get Started'}
                    {arrow}
                  </button>
                )
              }
              return (
                <a
                  href="/contact"
                  {...(calLink && isBookACallLabel(pkg.ctaLabel) ? {
                    'data-cal-link': calLink,
                    'data-cal-namespace': calNamespace,
                    'data-cal-config': '{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}',
                  } : {})}
                  class={ctaClass}
                >
                  {pkg.ctaLabel ?? 'Get Started'}
                  {arrow}
                </a>
              )
            })()}

            {pkg.features && pkg.features.length > 0 && (
              <ul class="space-y-3">
                {pkg.features.map(f => (
                  <li class="flex items-start gap-2.5 text-base text-text">
                    <svg class="w-4 h-4 mt-0.5 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
