---
import MainLayout from '../../layouts/MainLayout.astro'
import FAQ from '../../components/FAQ.astro'
import CTA from '../../components/CTA.astro'
import Metrics from '../../components/Metrics.astro'
import PageHeroBackground from '../../components/PageHeroBackground.astro'
import Spacer from '../../components/Spacer.astro'
import { fetchSanity } from '../../lib/sanity'
import { SERVICES_LIST_QUERY, SERVICE_BY_SLUG_QUERY } from '../../lib/queries'
import { breadcrumbSchema } from '../../lib/breadcrumbs'

function youtubeId(url?: string) {
  if (!url) return null
  const match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([\w-]{11})/)
  return match ? match[1] : null
}

export async function getStaticPaths() {
  const services = await fetchSanity<any[]>(SERVICES_LIST_QUERY)
  return (services ?? []).map((s: any) => ({ params: { slug: s.slug.current } }))
}

const { slug } = Astro.params

const [service, allServices] = await Promise.all([
  fetchSanity<any>(SERVICE_BY_SLUG_QUERY, { slug }),
  fetchSanity<any[]>(SERVICES_LIST_QUERY),
])

if (!service) return Astro.redirect('/services')

const ytId = youtubeId(service.videoUrl)
const otherServices = (allServices ?? []).filter((s: any) => s.slug.current !== slug).slice(0, 3)

// JSON-LD — Service schema
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: service.title,
  name: service.title,
  description: service.shortDescription,
  provider: { '@type': 'Organization', name: 'adnan.yt', url: 'https://adnan.yt' },
  ...(service.price && {
    offers: { '@type': 'Offer', price: service.price, priceCurrency: 'USD' },
  }),
}

const faqSchema = service.faqs?.length ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: service.faqs.map((f: any) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
} : null

const breadcrumbs = breadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Services', url: '/services' },
  { name: service.title, url: `/services/${slug}` },
])
---

<MainLayout
  title={service.seoTitle ?? `${service.title} | adnan.yt`}
  description={service.seoDescription ?? service.shortDescription}
  schema={faqSchema ? [serviceSchema, faqSchema, breadcrumbs] : [serviceSchema, breadcrumbs]}
>

  <!-- ══ HEADER ═════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden">
    <PageHeroBackground />
    <div class="container md:border-x md:border-border-light md:px-0 min-h-[300px] md:min-h-[400px] flex flex-col justify-center">
      <div class="px-6 md:pl-[30px] md:pr-8 py-10 md:py-14">
        <a href="/services" class="text-accent-light text-sm font-semibold hover:underline">← All Services</a>
        <h1 class="text-4xl md:text-5xl font-bold text-text-white mt-4 mb-3 tracking-tight max-w-[800px]">
          {service.icon && <span class="mr-2">{service.icon}</span>}{service.title}
        </h1>
        {service.shortDescription && (
          <p class="text-text-muted text-lg max-w-[800px]">{service.shortDescription}</p>
        )}
      </div>
    </div>
  </section>

  {service.stats?.length > 0 && <Metrics stats={service.stats} />}
  <Spacer borderBottom />

  <section class="py-20 border-b border-border">
    <div class="container grid lg:grid-cols-[1fr_360px] gap-12">
      <div>
        {ytId ? (
          <div class="relative aspect-video overflow-hidden border border-border mb-10">
            <span class="badge-accent absolute top-3 left-3 z-10 text-xs">Showreel</span>
            <iframe
              src={`https://www.youtube.com/embed/${ytId}`}
              class="w-full h-full" frameborder="0" allowfullscreen
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            />
          </div>
        ) : service.thumbnail && (
          <div class="relative mb-10">
            <span class="badge-accent absolute top-3 left-3 z-10 text-xs">Showreel</span>
            <img
              src={service.thumbnail} alt={service.title}
              class="w-full border border-border"
              loading="lazy"
            />
          </div>
        )}

        {service.fullDescription && (
          <div class="mb-10">
            <h2 class="text-xl font-extrabold text-text-white pb-4 mb-6 border-b border-border">Overview</h2>
            <p class="text-text-muted leading-6">{service.fullDescription}</p>
          </div>
        )}

        {service.deliverables?.length > 0 && (
          <div class="mb-10">
            <h2 class="text-xl font-extrabold text-text-white pb-4 mb-6 border-b border-border">What's Included</h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2.5">
              {service.deliverables.map((item: string) => (
                <li class="flex items-start gap-2.5 text-text">
                  <svg class="w-4 h-4 mt-1 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        )}

        {service.process?.length > 0 && (
          <div class="mb-10">
            <h2 class="section-heading">How We'll Work</h2>
            <div class="divide-y divide-border">
              {service.process.map((step: any, i: number) => (
                <div class="flex gap-4 py-5 first:pt-0 last:pb-0">
                  <span class="text-accent font-bold text-sm shrink-0 pt-0.5">{String(i + 1).padStart(2, '0')}</span>
                  <div>
                    <h3 class="font-bold text-text-white mb-1">{step.title}</h3>
                    {step.description && <p class="text-text-muted text-base leading-6">{step.description}</p>}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {service.faqs?.length > 0 && (
          <div>
            <h2 class="text-xl font-extrabold text-text-white pb-4 mb-6 border-b border-border">Frequently Asked Questions</h2>
            <FAQ items={service.faqs} hideTopBorder />
          </div>
        )}
      </div>

      <!-- ── Sidebar: pricing + CTA ── -->
      <aside class="space-y-6 lg:sticky lg:top-24 lg:self-start">
        <div class="card rounded-none">
          {service.price && (
            <div class="mb-4">
              <div class="text-text-muted text-sm mb-1">Starting from</div>
              <div class="flex items-baseline gap-1">
                <span class="text-4xl font-black text-text-white">{service.price}</span>
                {service.priceUnit && <span class="text-text-muted text-sm">/{service.priceUnit.replace(/^\/+/, '')}</span>}
              </div>
            </div>
          )}
          <button type="button" data-open-quote-modal class="group btn-primary w-full justify-center mb-3">
            Get a Free Quote
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <a href="/pricing" class="btn-secondary w-full justify-center">View All Packages</a>
          <div class="flex items-center gap-2 mt-4 text-text-muted text-xs">
            <span class="w-1.5 h-1.5 rounded-full bg-accent shrink-0"></span>
            Free quote within 24 hours
          </div>
        </div>

        {otherServices.length > 0 && (
          <div class="card rounded-none">
            <h3 class="text-text-white font-bold mb-4 text-sm uppercase tracking-wide">Other Services</h3>
            <ul class="space-y-1">
              {otherServices.map((s: any) => (
                <li>
                  <a href={`/services/${s.slug.current}`} class="group flex items-center justify-between gap-2 py-2 text-text-muted hover:text-text-white text-sm transition-colors">
                    <span>{s.title}</span>
                    <svg class="w-3.5 h-3.5 shrink-0 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="bg-[#111827] p-6">
          <h3 class="text-white font-bold mb-2">Not sure this is the right fit?</h3>
          <p class="text-white/60 text-sm leading-6 mb-4">
            Book a free 15-minute call and I'll point you to the right service — even if it's not mine.
          </p>
          <a href="/contact" class="inline-flex items-center gap-1.5 text-accent-light text-sm font-semibold hover:underline">
            Book a call →
          </a>
        </div>
      </aside>
    </div>
  </section>

  <CTA
    heading={`Ready to Start Your ${service.title}?`}
    subtext="Tell me about your project and get a free quote within 24 hours."
    primaryCta={{ label: 'Get a Free Quote →', href: '/contact' }}
    secondaryCta={{ label: 'View Pricing', href: '/pricing' }}
  />

</MainLayout>
