---
interface FaqItem {
  question: string
  answer: string
}
interface Props {
  items: FaqItem[]
}
const { items } = Astro.props as Props
---

<div class="border-t border-border-light">
  {items.map((item, i) => (
    <details class={`group border-border-light ${i < items.length - 1 ? 'border-b' : ''}`} name="faq-accordion" open={i === 0}>
      <summary class="flex items-center justify-between gap-4 px-6 md:px-8 py-6 cursor-pointer list-none font-semibold text-text-white text-lg">
        {item.question}
        <svg class="w-5 h-5 shrink-0 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </summary>
      <div class="px-6 md:px-8 pb-6 -mt-2 text-text-muted leading-relaxed">{item.answer}</div>
    </details>
  ))}
</div>
