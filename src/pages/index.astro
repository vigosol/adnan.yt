---
import MainLayout from '../layouts/MainLayout.astro'
import Hero from '../components/Hero.astro'
import Metrics from '../components/Metrics.astro'
import Spacer from '../components/Spacer.astro'
import AboutTeaser from '../components/AboutTeaser.astro'
import ServicesShowcase from '../components/ServicesShowcase.astro'
import PricingShowcase from '../components/PricingShowcase.astro'
import TestimonialCard from '../components/TestimonialCard.astro'
import PortfolioCard from '../components/PortfolioCard.astro'
import FAQ from '../components/FAQ.astro'
import CTA from '../components/CTA.astro'
import { fetchSanity, urlFor } from '../lib/sanity'
import {
  SITE_SETTINGS_QUERY, HOME_PAGE_QUERY, SERVICES_HOMEPAGE_QUERY, TESTIMONIALS_QUERY, PORTFOLIO_LIST_QUERY,
} from '../lib/queries'

const [settings, home, services, testimonials, portfolio] = await Promise.all([
  fetchSanity<any>(SITE_SETTINGS_QUERY),
  fetchSanity<any>(HOME_PAGE_QUERY),
  fetchSanity<any[]>(SERVICES_HOMEPAGE_QUERY),
  fetchSanity<any[]>(TESTIMONIALS_QUERY),
  fetchSanity<any[]>(PORTFOLIO_LIST_QUERY),
])

// Hero / Process / FAQs / Trust Stats are CMS-managed via the Home Page
// document — fall back to launch-day defaults until that's filled in.
const hero = {
  badge: home?.hero?.badge ?? 'Remote Video Editing Partner',
  title: home?.hero?.title ?? 'I turn your footage into video people',
  highlight: home?.hero?.highlight ?? 'actually finish.',
  subtitle: home?.hero?.subtitle ??
    'Retention first editing for YouTubers, founders, and brands. You film it. I turn it into videos people watch till the last second.',
  primaryCtaLabel: home?.hero?.primaryCtaLabel ?? 'Start a Project',
  secondaryCtaLabel: home?.hero?.secondaryCtaLabel ?? 'Watch The Reel',
  reelThumbnail: home?.hero?.reelThumbnail ? urlFor(home.hero.reelThumbnail).width(1218).height(714).url() : undefined,
  reelVideoUrl: home?.hero?.reelVideoUrl,
}

const aboutTeaser = {
  quote: home?.aboutTeaser?.quote ??
    'I help creators, founders, and brands turn raw footage into premium videos that audiences actually finish watching. Through thoughtful storytelling, cinematic pacing, sound design, and motion graphics, I create content that strengthens authority, increases engagement, and helps businesses grow through video.',
  ctaLabel: home?.aboutTeaser?.ctaLabel ?? 'Read the story',
}

const servicesSection = {
  badge: home?.servicesSection?.badge ?? 'Services',
  heading: home?.servicesSection?.heading ?? 'Everything your content needs, after the record button.',
  viewAllLabel: home?.servicesSection?.viewAllLabel ?? 'View all Services',
  tags: home?.servicesSection?.tags?.length ? home.servicesSection.tags : [
    'Youtube Video Editing', 'Podcast Editing', 'Youtube Shorts Editing', 'Instagram Reels Editing',
    'Tiktok Video Editing', 'Corporate Video Editing', 'Medical Video Editing', 'Real Estate Video Editing',
    'Event Video Editing', 'Interview Video Editing', 'Talking Head Video Editing', 'Social Media Video Editing',
    'Ecommerce Video Editing', 'Explainer Video Editing', 'Audio Enhancement', 'Video Color Grading',
    'Video Repurposing', 'Subtitle and Caption Editing',
  ],
}

const processSteps = home?.process?.length ? home.process : [
  { icon: '📋', title: 'Brief',   description: 'Fill out the project form with your goals, style references, and deadline.' },
  { icon: '📁', title: 'Upload',  description: 'Share your raw footage via Google Drive or WeTransfer.' },
  { icon: '✂️', title: 'Edit',    description: 'I edit, colour-grade, and add music/captions to your spec.' },
  { icon: '🚀', title: 'Deliver', description: 'Receive your polished video. One round of revisions included.' },
]

const faqs = home?.faqs?.length ? home.faqs : [
  { question: 'How fast is turnaround?', answer: 'Most projects are delivered within 24–48 hours, depending on length and complexity.' },
  { question: 'How many revisions are included?', answer: 'One round of revisions is included with every project. Additional rounds can be added on request.' },
  { question: 'What file formats do you accept?', answer: 'Any common format — MP4, MOV, or raw camera footage. Share it via Google Drive or WeTransfer.' },
  { question: 'Do you sign NDAs?', answer: 'Yes — happy to sign an NDA before you share any footage, just ask.' },
]

const trustStats = home?.trustStats?.length ? home.trustStats : [
  { val: '400+',   label: 'Projects delivered', description: 'Delivered high-performing videos across multiple industries and content formats.' },
  { val: '60+',    label: 'Creators & Brands',  description: 'Trusted by creators, startups, businesses, and growing personal brands worldwide.' },
  { val: '24-72h', label: 'Average Turaround',  description: 'Fast delivery without compromising storytelling, quality, or viewer retention.' },
  { val: '4.9',    label: 'Client Rating',      description: 'Consistently rated highly for communication, quality, and reliability.' },
]

const pricingSection = {
  badge: home?.pricingSection?.badge ?? 'Pricing',
  heading: home?.pricingSection?.heading ?? 'Choose the best package for you',
  subtitle: home?.pricingSection?.subtitle ?? 'Transparent pricing. No hidden costs. Just results.',
  packages: home?.pricingSection?.packages?.length ? home.pricingSection.packages : [
    {
      title: 'Single Edit', price: '199', period: 'video',
      description: 'A single short or long form video edit',
      ctaLabel: 'Book a Call',
      featured: false,
      features: [
        'One fully-edited video (short or long-form)', 'Fast 3-5 day turnaround', 'Captions/subtitles included',
        'Color grading & sound mixing', '2 round of revisions', 'Thumbnail poster included',
        'Short up to 60 sec, Long up to 2 mins',
      ],
    },
    {
      title: 'Regular Edit', price: '1999', period: 'month',
      description: 'Growing brands aiming for post regularly',
      ctaLabel: 'Subscribe Now',
      featured: true,
      features: [
        'Up to 15 edited videos per month', 'Priority 2-3 day turnaround', 'Unlimited revisions',
        'Regular updates', 'Strategy support for content', 'Thumbnail poster included', 'One video at a time',
      ],
    },
  ],
  helpPanel: {
    block1Heading: home?.pricingSection?.helpPanel?.block1Heading ?? "Still can't decide?",
    block1Subtext: home?.pricingSection?.helpPanel?.block1Subtext ?? "Let's figure out what you need",
    block1CtaLabel: home?.pricingSection?.helpPanel?.block1CtaLabel ?? "Let's Talk",
    block2Heading: home?.pricingSection?.helpPanel?.block2Heading ?? 'Get a free quote',
    block2Subtext: home?.pricingSection?.helpPanel?.block2Subtext ?? 'Free quote, no obligation.',
    block2CtaLabel: home?.pricingSection?.helpPanel?.block2CtaLabel ?? 'Get Quote',
  },
}

// JSON-LD — Organization schema
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'adnan.yt',
  url: 'https://adnan.yt',
  logo: 'https://adnan.yt/logo.png',
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: settings?.phone ?? '',
    contactType: 'customer service',
  },
  sameAs: [
    settings?.socialLinks?.youtube,
    settings?.socialLinks?.instagram,
    settings?.socialLinks?.linkedin,
  ].filter(Boolean),
}

// JSON-LD — FAQPage schema
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f: any) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
}
---

<MainLayout
  title="Muhammad Adnan — Professional Video Editing Services | adnan.yt"
  description="Professional YouTube, Reels, podcast & corporate video editing. Fast turnaround, competitive pricing. Get your free quote today."
  schema={[orgSchema, faqSchema]}
>

  <!-- ══ HERO ══════════════════════════════════════════════════════ -->
  <Hero
    badge={hero.badge}
    title={hero.title}
    highlight={hero.highlight}
    subtitle={hero.subtitle}
    primaryCta={{ label: hero.primaryCtaLabel, href: '/contact' }}
    secondaryCta={{ label: hero.secondaryCtaLabel, href: '#reel' }}
    reelThumbnail={hero.reelThumbnail}
    reelVideoUrl={hero.reelVideoUrl}
  />

  <!-- ══ ABOUT TEASER ═══════════════════════════════════════════════ -->
  <Spacer />
  <AboutTeaser quote={aboutTeaser.quote} ctaLabel={aboutTeaser.ctaLabel} />

  <!-- ══ METRICS ═══════════════════════════════════════════════════ -->
  <Metrics stats={trustStats} />
  <Spacer />

  <!-- ══ SERVICES ═══════════════════════════════════════════════════ -->
  <ServicesShowcase
    badge={servicesSection.badge}
    heading={servicesSection.heading}
    viewAllLabel={servicesSection.viewAllLabel}
    services={services ?? []}
    tags={servicesSection.tags}
  />

  <!-- ══ PRICING ════════════════════════════════════════════════════ -->
  <Spacer borderBottom />
  <PricingShowcase
    badge={pricingSection.badge}
    heading={pricingSection.heading}
    subtitle={pricingSection.subtitle}
    packages={pricingSection.packages}
    helpPanel={pricingSection.helpPanel}
  />

  <!-- ══ FAQs ═══════════════════════════════════════════════════════ -->
  <Spacer borderTop />
  <section>
    <div class="container md:border-x md:border-t md:border-border-light md:px-0">
      <div class="px-6 md:pl-[30px] md:pr-8 py-10 md:py-14">
        <span class="inline-block border border-border-light rounded-full text-xs font-normal px-3 py-1 text-text-muted mb-4">FAQs</span>
        <h2 class="text-4xl md:text-5xl font-bold text-text-white">Frequently Asked Questions</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <!-- ══ FEATURED WORK ═════════════════════════════════════════════ -->
  <section class="py-24 border-t border-border bg-bg-1">
    <div class="container">
      <h2 class="section-heading">Featured Work</h2>
      <p class="text-text-muted mb-12 max-w-xl">
        Real results for real clients — see the edits in action.
      </p>

      {portfolio?.length ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {portfolio.slice(0, 6).map((item: any) => (
            <PortfolioCard item={item} />
          ))}
        </div>
      ) : (
        <p class="text-text-muted text-sm">Portfolio items will appear here once added in Sanity Studio.</p>
      )}

      <div class="text-center mt-10">
        <a href="/portfolio" class="btn-secondary">View Full Portfolio →</a>
      </div>
    </div>
  </section>

  <!-- ══ PROCESS ════════════════════════════════════════════════════ -->
  <section class="py-24 border-t border-border">
    <div class="container">
      <h2 class="section-heading">How It Works</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-8">
        {processSteps.map((step: any, i: number) => (
          <div class="card relative">
            <div class="text-4xl font-black text-border absolute top-4 right-4">{String(i + 1).padStart(2, '0')}</div>
            <div class="text-3xl mb-3">{step.icon}</div>
            <h3 class="font-bold text-text-white mb-2">{step.title}</h3>
            <p class="text-text-muted text-sm">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ TESTIMONIALS ═══════════════════════════════════════════════ -->
  {testimonials?.length > 0 && (
    <section class="py-24 border-t border-border">
      <div class="container">
        <h2 class="section-heading">Client Results</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 mt-8">
          {testimonials.slice(0, 6).map((t: any) => (
            <TestimonialCard testimonial={t} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ══ CTA BANNER ════════════════════════════════════════════════ -->
  <CTA
    heading="Ready to Elevate Your Videos?"
    subtext="Let's talk about your project. Free quote, no obligation."
    primaryCta={{ label: 'Get Your Free Quote →', href: '/contact' }}
    secondaryCta={{ label: 'View Pricing', href: '/pricing' }}
  />

</MainLayout>