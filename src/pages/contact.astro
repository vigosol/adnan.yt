---
import MainLayout from '../layouts/MainLayout.astro'
import FAQ from '../components/FAQ.astro'
import DatePicker from '../components/DatePicker.astro'
import PhoneInput from '../components/PhoneInput.astro'
import PageHeroBackground from '../components/PageHeroBackground.astro'
import Spacer from '../components/Spacer.astro'
import { fetchSanity } from '../lib/sanity'
import { reverseText } from '../lib/obfuscate'
import { SITE_SETTINGS_QUERY, CONTACT_PAGE_QUERY, SERVICES_LIST_QUERY } from '../lib/queries'
import { breadcrumbSchema } from '../lib/breadcrumbs'

const [settings, contact, services] = await Promise.all([
  fetchSanity<any>(SITE_SETTINGS_QUERY),
  fetchSanity<any>(CONTACT_PAGE_QUERY),
  fetchSanity<any[]>(SERVICES_LIST_QUERY),
])

const serviceOptions = services?.length
  ? services.map((s: any) => s.title)
  : ['YouTube Video Editing', 'Shorts & Reels Editing', 'Podcast Video Editing', 'Motion Graphics', 'Corporate Video', 'Other']

const budgetOptions = ['Under $200', '$200 – $500', '$500 – $1,000', '$1,000+', 'Not sure yet']

// Contact page copy is CMS-managed via the Contact Page document — fall
// back to launch-day defaults until that content is filled in.
const contactCopy = {
  title: contact?.title ?? "Let's Talk About Your",
  highlight: contact?.highlight ?? 'Project',
  subtitle: contact?.subtitle ?? 'Fill out the form below and get a free, no-obligation quote within 24 hours.',
  responseTime: contact?.responseTime ?? 'within 24 hours, usually sooner.',
}

const faqs = contact?.faqs?.length ? contact.faqs : [
  { question: 'How fast will you respond?', answer: "Within 24 hours, usually much sooner. You'll also get an automatic confirmation email right after submitting." },
  { question: 'Do you sign NDAs?', answer: 'Yes — happy to sign an NDA before you share any footage, just mention it in your message.' },
  { question: "What if I'm not sure which service I need?", answer: 'Pick "Other" or describe your project in the details field — I\'ll recommend the right service during the quote.' },
]
---

<MainLayout
  title="Contact — Get a Free Quote | adnan.yt"
  description="Tell me about your video project and get a free, no-obligation quote within 24 hours."
  schema={breadcrumbSchema([{ name: 'Home', url: '/' }, { name: 'Contact', url: '/contact' }])}
>

  <section class="relative overflow-hidden">
    <PageHeroBackground />
    <div class="container md:border-x md:border-border-light md:px-0 min-h-[300px] md:min-h-[400px] flex flex-col justify-center">
      <div class="px-6 md:pl-[30px] md:pr-8 py-10 md:py-14">
        <span class="inline-block border border-border-light rounded-full text-xs font-normal px-3 py-1 text-text-muted mb-4">Contact</span>
        <h1 class="text-4xl md:text-5xl font-bold text-text-white mb-3 tracking-tight max-w-[800px]">
          {contactCopy.title} <span class="text-accent">{contactCopy.highlight}</span>
        </h1>
        <p class="text-text-muted text-lg max-w-[800px]">
          {contactCopy.subtitle}
        </p>
      </div>
    </div>
  </section>

  <Spacer borderTop borderBottom />

  <section class="py-20">
    <div class="container md:border-x md:border-border-light md:px-0">
    <div class="px-6 md:pl-[30px] md:pr-8 grid lg:grid-cols-[1fr_360px] gap-12">
      <!-- ── Inquiry form ── -->
      <form id="contact-form" class="space-y-5" novalidate>
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="label">Name</label>
            <input id="name" name="name" type="text" required class="input rounded-none py-4" placeholder="Your name" />
          </div>
          <div>
            <label for="email" class="label">Email</label>
            <input id="email" name="email" type="email" required class="input rounded-none py-4" placeholder="you@example.com" />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="service" class="label">Service Interested In</label>
            <select id="service" name="service" class="input rounded-none py-4">
              {serviceOptions.map((s: string) => <option value={s}>{s}</option>)}
            </select>
          </div>
          <div>
            <label for="budget" class="label">Budget Range</label>
            <select id="budget" name="budget" class="input rounded-none py-4">
              {budgetOptions.map((b: string) => <option value={b}>{b}</option>)}
            </select>
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <PhoneInput id="whatsapp" name="whatsapp" label="WhatsApp" />
          <DatePicker id="deadline" name="deadline" label="Deadline (optional)" placeholder="Select a date" />
        </div>

        <div>
          <label for="message" class="label">Project Details</label>
          <textarea
            id="message" name="message" rows="6" required class="input rounded-none resize-none"
            placeholder="Tell me about your project — goals, style references, footage length, anything else useful."
          ></textarea>
        </div>

        <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY} data-theme="auto"></div>

        <button type="submit" id="contact-submit" class="btn-primary w-full justify-center text-base rounded-none">
          Send Project Details →
        </button>

        <p id="contact-status" class="text-sm hidden" role="status"></p>
      </form>

      <!-- ── Sidebar: direct contact + expectations — sticky until it runs out of column ── -->
      <aside class="space-y-6 lg:sticky lg:top-24 lg:self-start">
        <div class="card rounded-none">
          <h3 class="text-text-white font-bold mb-3">Prefer to reach out directly?</h3>
          <div class="space-y-3 text-sm">
            {settings?.email && (
              <a
                href={`mailto:${settings.email}`}
                aria-label={settings.email}
                class="flex items-center gap-2 py-2 text-text-muted hover:text-text-white transition-colors"
              >
                <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <rect x="3" y="5" width="18" height="14" rx="2" />
                  <path d="M3 7l9 6 9-6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <span style="unicode-bidi: bidi-override; direction: rtl;" aria-hidden="true">{reverseText(settings.email)}</span>
              </a>
            )}
            {settings?.enableWhatsapp && settings?.whatsappNumber && (
              <a
                href={`https://wa.me/${settings.whatsappNumber}`} target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-2 py-2 text-text-muted hover:text-text-white transition-colors"
              >
                <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Chat on WhatsApp
              </a>
            )}
          </div>
        </div>

        <div class="callout-info rounded-none">
          <span class="callout-icon">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 7v5l3 3" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <div><strong>Response time:</strong> {contactCopy.responseTime}</div>
        </div>
      </aside>
    </div>
    </div>
  </section>

  <!-- ══ QUICK QUESTIONS — full width, below the form/sidebar ══════════ -->
  <Spacer borderTop />
  <section>
    <div class="container md:border-x md:border-t md:border-border-light md:px-0">
      <div class="px-6 md:pl-[30px] md:pr-8 py-10 md:py-14">
        <span class="inline-block border border-border-light rounded-full text-xs font-normal px-3 py-1 text-text-muted mb-4">FAQs</span>
        <h2 class="text-4xl md:text-5xl font-bold text-text-white tracking-tight max-w-[800px]">Frequently Asked Questions</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <Spacer borderTop />

</MainLayout>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement
  const status = document.getElementById('contact-status') as HTMLParagraphElement

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()

    const data = Object.fromEntries(new FormData(form).entries())

    submitBtn.disabled = true
    submitBtn.textContent = 'Sending...'
    status.classList.add('hidden')

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      })
      const result = await res.json()

      if (result.success) {
        ;(window as any).showToast?.('Message sent!', "Thanks for reaching out — I'll be in touch within 24 hours.")
        form.reset()
      } else {
        status.classList.remove('hidden')
        status.textContent = result.error ?? 'Something went wrong. Please try again.'
        status.className = 'text-sm text-error'
      }
    } catch {
      status.classList.remove('hidden')
      status.textContent = 'Network error — please check your connection and try again.'
      status.className = 'text-sm text-error'
    } finally {
      submitBtn.disabled = false
      submitBtn.textContent = 'Send Project Details →'
    }
  })
</script>
