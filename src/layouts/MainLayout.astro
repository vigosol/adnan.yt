---
import '../styles/global.css'
import { sanityClient } from '../lib/sanity'
import { SITE_SETTINGS_QUERY } from '../lib/queries'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'
import QuoteModal from '../components/QuoteModal.astro'
import Toast from '../components/Toast.astro'
import { normalizeCalLink, getCalNamespace } from '../lib/cal'

interface Props {
  title?:       string
  description?: string
  ogImage?:     string
  canonical?:   string
  schema?:      object | object[]   // JSON-LD schema(s)
  noindex?:     boolean
  hideFloatingWhatsApp?: boolean   // suppress the floating bubble on pages that already have a prominent WhatsApp CTA (e.g. Contact)
}

const settings = await sanityClient.fetch(SITE_SETTINGS_QUERY)

const {
  title       = settings?.defaultSeoTitle       ?? 'Muhammad Adnan — Professional Video Editor',
  description = settings?.defaultSeoDescription ?? 'Hire a professional video editor for YouTube, Reels, podcasts, and corporate video. Based in Pakistan, working globally.',
  ogImage     = settings?.defaultOgImage?.asset?.url ?? '/og-default.jpg',
  canonical   = Astro.url.href,
  schema,
  noindex     = false,
  hideFloatingWhatsApp = false,
} = Astro.props

const ga4Id  = settings?.ga4Id
const gtmId  = settings?.gtmId
const siteName = settings?.siteName ?? 'adnan.yt'

const calLink = normalizeCalLink(settings?.calBooking?.calLink)
const calNamespace = getCalNamespace(calLink)

// Normalise schema to array
const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : []
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#fafaf9" />

  <!-- Apply saved/preferred theme before first paint to avoid a flash -->
  <script is:inline>
    (function () {
      var stored = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      var isDark = stored === 'dark' || (!stored && prefersDark);
      if (isDark) document.documentElement.classList.add('dark');
    })();
  </script>

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonical} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:site_name"   content={siteName} />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- Fonts preloaded from /public/fonts (Euclid Circular A) — Bold is
       included since headings sitewide (including the hero H1) use it,
       and would otherwise only be discoverable after the CSS is parsed. -->
  <link rel="preload" href="/fonts/EuclidCircularA-Regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/EuclidCircularA-Medium.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/EuclidCircularA-Bold.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Tag Manager (head) -->
  {gtmId && (
    <script define:vars={{ gtmId }}>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer', gtmId);
    </script>
  )}

  <!-- GA4 (fallback if no GTM) -->
  {ga4Id && !gtmId && (
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
    <script define:vars={{ ga4Id }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', ga4Id);
    </script>
  )}

  <!-- JSON-LD Schema -->
  {schemas.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}

  <!-- Extra head slot -->
  <slot name="head" />
</head>

<body class="bg-bg text-text antialiased">

  <!-- GTM noscript -->
  {gtmId && (
    <noscript>
      <iframe src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
        height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>
  )}

  <!-- ── Navigation ── -->
  <slot name="nav">
    <Header />
  </slot>

  <!-- ── Page content ── -->
  <main>
    <slot />
  </main>

  <!-- ── Footer ── -->
  <slot name="footer">
    <Footer settings={settings} />
  </slot>

  <!-- ── WhatsApp Float (suppressed on pages with their own prominent WhatsApp CTA) ── -->
  {!hideFloatingWhatsApp && <WhatsAppButton settings={settings} />}

  <!-- ── Success toast (triggered via window.showToast(title, message)) ── -->
  <Toast />

  <!-- ── Get a Free Quote modal (opened by any [data-open-quote-modal] trigger) ── -->
  <QuoteModal settings={settings} />

  <!-- ── Cal.com booking popup (opened by any [data-cal-link] trigger) ── -->
  {calLink && calNamespace && (
    <script type="text/javascript" define:vars={{ calNamespace }}>
      (function (C, A, L) {
        let p = function (a, ar) { a.q.push(ar) }
        let d = C.document
        C.Cal = C.Cal || function () {
          let cal = C.Cal
          let ar = arguments
          if (!cal.loaded) {
            cal.ns = {}
            cal.q = cal.q || []
            const embedScript = d.createElement('script')
            embedScript.src = A
            // Only trust the popup to open once this script has actually
            // loaded — if Cal.com/Cloudflare blocks or fails to serve it,
            // embedReady stays false and the click handler below lets the
            // real href="/contact" navigation through instead of silently
            // eating the click with no popup to show for it.
            embedScript.onload = function () { cal.embedReady = true }
            embedScript.onerror = function () { cal.embedReady = false }
            d.head.appendChild(embedScript)
            cal.loaded = true
          }
          if (ar[0] === L) {
            const api = function () { p(api, arguments) }
            const namespace = ar[1]
            api.q = api.q || []
            if (typeof namespace === 'string') {
              cal.ns[namespace] = cal.ns[namespace] || api
              p(cal.ns[namespace], ar)
              p(cal, ['initNamespace', namespace])
            } else p(cal, ar)
            return
          }
          p(cal, ar)
        }
      })(window, 'https://app.cal.com/embed/embed.js', 'init')

      Cal('init', calNamespace, { origin: 'https://app.cal.com' })
      Cal.config = Cal.config || {}
      Cal.config.forwardQueryParams = true
      Cal.ns[calNamespace]('ui', { hideEventTypeDetails: false, layout: 'month_view' })

      // Cal's own click handler opens the modal but doesn't call
      // preventDefault(), so a real href="/contact" fallback (kept for
      // no-JS visitors) would otherwise navigate away before the modal
      // finishes opening. Block the default navigation only once Cal's
      // embed script has confirmed it loaded — otherwise let the fallback
      // link work normally so a blocked/failed embed never leaves visitors
      // stuck on a dead button.
      document.addEventListener('click', (e) => {
        const trigger = e.target instanceof Element ? e.target.closest('[data-cal-link]') : null
        if (trigger && Cal.embedReady) e.preventDefault()
      })
    </script>
  )}

  <!-- ── Scripts slot ── -->
  <slot name="scripts" />

</body>
</html>
