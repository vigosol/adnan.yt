---
interface Props {
  id: string
  name: string
  label?: string
  placeholder?: string
}
const { id, name, label, placeholder = 'Select a date' } = Astro.props as Props
---

<div data-datepicker>
  {label && <label for={id} class="label">{label}</label>}
  <div class="relative">
    <input
      type="text"
      id={id}
      readonly
      autocomplete="off"
      placeholder={placeholder}
      class="input rounded-none py-4 pr-10 cursor-pointer"
      data-datepicker-display
      aria-haspopup="dialog"
      aria-expanded="false"
    />
    <svg class="pointer-events-none absolute right-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <rect x="3" y="5" width="18" height="16" />
      <path d="M3 10h18M8 3v4M16 3v4" stroke-linecap="round" />
    </svg>
  </div>
  <input type="hidden" name={name} data-datepicker-value />

  <div
    class="hidden absolute z-20 mt-2 w-[280px] bg-bg-1 border border-border shadow-card p-4"
    data-datepicker-panel
    role="dialog"
    aria-label="Choose a date"
  >
    <div class="flex items-center justify-between mb-3">
      <button type="button" class="w-8 h-8 flex items-center justify-center text-text-muted hover:text-text-white transition-colors" data-prev-month aria-label="Previous month">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </button>
      <span class="text-text-white font-semibold text-sm" data-month-label></span>
      <button type="button" class="w-8 h-8 flex items-center justify-center text-text-muted hover:text-text-white transition-colors" data-next-month aria-label="Next month">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </button>
    </div>
    <div class="grid grid-cols-7 gap-1 mb-1">
      {['Su', 'Mo', 'Tu', 'We', 'Th', 'Fr', 'Sa'].map(d => (
        <div class="text-center text-[11px] font-semibold text-text-muted py-1">{d}</div>
      ))}
    </div>
    <div class="grid grid-cols-7 gap-1" data-days-grid></div>
  </div>
</div>

<script>
  function initDatePickers() {
    document.querySelectorAll<HTMLElement>('[data-datepicker]').forEach(root => {
      // Skip roots already wired (this script can run again after client-side navigation)
      if (root.dataset.datepickerReady) return
      root.dataset.datepickerReady = 'true'

      const display = root.querySelector<HTMLInputElement>('[data-datepicker-display]')
      const hidden = root.querySelector<HTMLInputElement>('[data-datepicker-value]')
      const panel = root.querySelector<HTMLElement>('[data-datepicker-panel]')
      const monthLabel = root.querySelector<HTMLElement>('[data-month-label]')
      const daysGrid = root.querySelector<HTMLElement>('[data-days-grid]')
      const prevBtn = root.querySelector<HTMLButtonElement>('[data-prev-month]')
      const nextBtn = root.querySelector<HTMLButtonElement>('[data-next-month]')
      if (!display || !hidden || !panel || !monthLabel || !daysGrid) return

      const today = new Date()
      today.setHours(0, 0, 0, 0)
      let viewYear = today.getFullYear()
      let viewMonth = today.getMonth()
      let selected: Date | null = null

      const MONTHS = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December']

      const pad = (n: number) => String(n).padStart(2, '0')
      const toISO = (d: Date) => `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`
      const toDisplay = (d: Date) => `${MONTHS[d.getMonth()].slice(0, 3)} ${d.getDate()}, ${d.getFullYear()}`

      function render() {
        monthLabel!.textContent = `${MONTHS[viewMonth]} ${viewYear}`
        daysGrid!.innerHTML = ''

        const firstDay = new Date(viewYear, viewMonth, 1).getDay()
        const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate()

        for (let i = 0; i < firstDay; i++) {
          daysGrid!.appendChild(document.createElement('div'))
        }

        for (let day = 1; day <= daysInMonth; day++) {
          const date = new Date(viewYear, viewMonth, day)
          const isPast = date < today
          const isToday = date.getTime() === today.getTime()
          const isSelected = selected !== null && date.getTime() === selected.getTime()

          const btn = document.createElement('button')
          btn.type = 'button'
          btn.textContent = String(day)
          btn.className = [
            'w-9 h-9 text-sm flex items-center justify-center transition-colors',
            isSelected
              ? 'bg-accent text-white font-semibold'
              : isToday
              ? 'border border-accent text-accent font-semibold'
              : isPast
              ? 'text-text-muted opacity-40 cursor-not-allowed'
              : 'text-text hover:bg-bg-2',
          ].join(' ')

          if (isPast) {
            btn.disabled = true
          } else {
            btn.addEventListener('click', () => {
              selected = date
              hidden!.value = toISO(date)
              display!.value = toDisplay(date)
              closePanel()
            })
          }

          daysGrid!.appendChild(btn)
        }
      }

      function openPanel() {
        panel!.classList.remove('hidden')
        display!.setAttribute('aria-expanded', 'true')
      }
      function closePanel() {
        panel!.classList.add('hidden')
        display!.setAttribute('aria-expanded', 'false')
      }
      function togglePanel() {
        if (panel!.classList.contains('hidden')) openPanel()
        else closePanel()
      }

      display.addEventListener('click', togglePanel)

      prevBtn?.addEventListener('click', () => {
        viewMonth -= 1
        if (viewMonth < 0) { viewMonth = 11; viewYear -= 1 }
        render()
      })
      nextBtn?.addEventListener('click', () => {
        viewMonth += 1
        if (viewMonth > 11) { viewMonth = 0; viewYear += 1 }
        render()
      })

      document.addEventListener('click', (e) => {
        if (!root.contains(e.target as Node)) closePanel()
      })
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closePanel()
      })

      render()
    })
  }

  initDatePickers()
</script>
