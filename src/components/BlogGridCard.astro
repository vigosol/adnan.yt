---
import { excerpt } from '../lib/text'

interface Props {
  post: {
    title: string
    slug: { current: string } | string
    publishedAt?: string
    category?: string
    bodyText?: string
    thumbnail?: string
  }
}
const { post } = Astro.props as Props
const slug = typeof post.slug === 'string' ? post.slug : post.slug.current
const date = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  : null

const WORDS_PER_MINUTE = 200
function readingTime(bodyText?: string) {
  const words = bodyText?.trim().split(/\s+/).filter(Boolean).length ?? 0
  return Math.max(1, Math.round(words / WORDS_PER_MINUTE))
}
---

<a href={`/blog/${slug}`} class="group block border border-border-light hover:border-border transition-colors">
  <div class="aspect-video overflow-hidden bg-bg-2">
    {post.thumbnail ? (
      <img
        src={post.thumbnail} alt={post.title} loading="lazy"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-text-muted">
        <svg class="w-10 h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M6 2h9l5 5v13a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M14 2v6h6" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M8 13h8M8 17h5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
    )}
  </div>
  <div class="p-4">
    <div class="flex items-center gap-2 text-xs text-text-muted mb-2">
      {date && <span>{date}</span>}
      {date && <span>&middot;</span>}
      <span>{readingTime(post.bodyText)} min read</span>
    </div>
    <h3 class="text-text-white font-bold mb-2 leading-6 min-h-12 group-hover:text-accent-light transition-colors">
      {post.title}
    </h3>
    {excerpt(post.bodyText) && (
      <p class="text-text-muted text-base leading-6 line-clamp-2 min-h-12 mb-3">{excerpt(post.bodyText)}</p>
    )}
    <span class="inline-flex items-center gap-1.5 text-accent-text text-sm font-semibold">
      Read More
      <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
  </div>
</a>
