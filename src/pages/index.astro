---
import MainLayout from '../layouts/MainLayout.astro'
import { fetchSanity } from '../lib/sanity'
import { SITE_SETTINGS_QUERY, SERVICES_LIST_QUERY, TESTIMONIALS_QUERY } from '../lib/queries'

const [settings, services, testimonials] = await Promise.all([
  fetchSanity(SITE_SETTINGS_QUERY),
  fetchSanity(SERVICES_LIST_QUERY),
  fetchSanity(TESTIMONIALS_QUERY),
])

// JSON-LD — Organization schema
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'adnan.yt',
  url: 'https://adnan.yt',
  logo: 'https://adnan.yt/logo.png',
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: settings?.phone ?? '',
    contactType: 'customer service',
  },
  sameAs: [
    settings?.socialLinks?.youtube,
    settings?.socialLinks?.instagram,
    settings?.socialLinks?.linkedin,
  ].filter(Boolean),
}
---

<MainLayout
  title="Muhammad Adnan — Professional Video Editing Services | adnan.yt"
  description="Professional YouTube, Reels, podcast & corporate video editing. Fast turnaround, competitive pricing. Get your free quote today."
  schema={orgSchema}
>

  <!-- ══ HERO ══════════════════════════════════════════════════════ -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden">
    <!-- Background glow -->
    <div class="absolute inset-0 bg-gradient-site pointer-events-none" />
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-accent/5 rounded-full blur-3xl" />

    <div class="container relative z-10 py-24 text-center">
      <!-- Trust badge -->
      <div class="inline-flex items-center gap-2 badge-accent mb-6 text-sm">
        <span class="w-2 h-2 rounded-full bg-success animate-pulse"></span>
        Available for new projects
      </div>

      <!-- Headline -->
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-black leading-[1.05] mb-6 tracking-tight">
        Video Editing That<br />
        <span class="text-gradient">Grows Your Channel</span>
      </h1>

      <!-- Sub-headline -->
      <p class="text-lg md:text-xl text-text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
        Professional editing for YouTube creators, coaches, agencies, and brands.
        Fast delivery. Cinematic quality. Zero revision stress.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="/contact" class="btn-primary text-base px-8 py-4">
          Get a Free Quote →
        </a>
        <a href="/portfolio" class="btn-secondary text-base px-8 py-4">
          View Portfolio
        </a>
      </div>

      <!-- Social proof numbers -->
      <div class="flex flex-wrap gap-8 justify-center mt-16 text-center">
        {[
          { val: '100+', label: 'Videos Edited' },
          { val: '50+',  label: 'Happy Clients' },
          { val: '24h',  label: 'Avg. Turnaround' },
          { val: '5★',   label: 'Average Rating' },
        ].map(({ val, label }) => (
          <div>
            <div class="text-3xl font-black text-gradient">{val}</div>
            <div class="text-sm text-text-muted mt-1">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ SERVICES ═══════════════════════════════════════════════════ -->
  <section class="py-24 border-t border-border">
    <div class="container">
      <h2 class="section-heading">Services</h2>
      <p class="text-text-muted mb-12 max-w-xl">
        Everything you need to produce scroll-stopping video content — from raw footage to publish-ready.
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {services?.length ? services.map((service: any) => (
          <a href={`/services/${service.slug.current}`} class="card-hover group">
            <div class="text-2xl mb-3">{service.icon ?? '🎬'}</div>
            <h3 class="text-text-white font-bold text-lg mb-2 group-hover:text-accent-light transition-colors">
              {service.title}
            </h3>
            <p class="text-text-muted text-sm leading-relaxed">{service.shortDescription}</p>
            {service.price && (
              <div class="mt-4 text-accent font-semibold text-sm">Starting from {service.price}</div>
            )}
          </a>
        )) : (
          <>
            {['YouTube Video Editing', 'Shorts & Reels Editing', 'Podcast Video Editing',
              'Motion Graphics', 'Corporate Video', 'Social Media Packages'].map(name => (
              <div class="card">
                <div class="text-2xl mb-3">🎬</div>
                <h3 class="text-text-white font-bold text-lg mb-2">{name}</h3>
                <p class="text-text-muted text-sm">Add service details in Sanity Studio.</p>
              </div>
            ))}
          </>
        )}
      </div>

      <div class="text-center mt-10">
        <a href="/services" class="btn-secondary">View All Services →</a>
      </div>
    </div>
  </section>

  <!-- ══ PROCESS ════════════════════════════════════════════════════ -->
  <section class="py-24 border-t border-border bg-bg-1">
    <div class="container">
      <h2 class="section-heading">How It Works</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-8">
        {[
          { n: '01', icon: '📋', title: 'Brief',   desc: 'Fill out the project form with your goals, style references, and deadline.' },
          { n: '02', icon: '📁', title: 'Upload',  desc: 'Share your raw footage via Google Drive or WeTransfer.' },
          { n: '03', icon: '✂️', title: 'Edit',    desc: 'I edit, colour-grade, and add music/captions to your spec.' },
          { n: '04', icon: '🚀', title: 'Deliver', desc: 'Receive your polished video. One round of revisions included.' },
        ].map(step => (
          <div class="card relative">
            <div class="text-4xl font-black text-border absolute top-4 right-4">{step.n}</div>
            <div class="text-3xl mb-3">{step.icon}</div>
            <h3 class="font-bold text-text-white mb-2">{step.title}</h3>
            <p class="text-text-muted text-sm">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ TESTIMONIALS ═══════════════════════════════════════════════ -->
  {testimonials?.length > 0 && (
    <section class="py-24 border-t border-border">
      <div class="container">
        <h2 class="section-heading">Client Results</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 mt-8">
          {testimonials.slice(0, 6).map((t: any) => (
            <div class="card">
              <div class="flex items-center gap-1 text-gold mb-3">
                {'★'.repeat(t.rating ?? 5)}
              </div>
              <p class="text-text-muted text-sm leading-relaxed mb-4">"{t.quote}"</p>
              <div class="flex items-center gap-3">
                {t.avatar && <img src={t.avatar} alt={t.name} class="w-9 h-9 rounded-full object-cover" />}
                <div>
                  <div class="font-semibold text-text-white text-sm">{t.name}</div>
                  {t.company && <div class="text-text-muted text-xs">{t.company}</div>}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ══ CTA BANNER ════════════════════════════════════════════════ -->
  <section class="py-24 border-t border-border">
    <div class="container text-center">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-black text-text-white mb-4">
          Ready to Elevate Your Videos?
        </h2>
        <p class="text-text-muted mb-8">
          Let's talk about your project. Free quote, no obligation.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact"  class="btn-primary text-base px-8 py-4">Get Your Free Quote →</a>
          <a href="/pricing"  class="btn-secondary text-base px-8 py-4">View Pricing</a>
        </div>
      </div>
    </div>
  </section>

</MainLayout>