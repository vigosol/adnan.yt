---
// Global success toast — mounted once in MainLayout, triggered from any
// page/form via window.showToast(title, message). Auto-dismisses after 3s.
---

<div
  id="site-toast"
  class="fixed top-20 left-1/2 -translate-x-1/2 z-[100] pointer-events-none opacity-0 -translate-y-2 transition-all duration-300 ease-out"
  role="status"
  aria-live="polite"
>
  <div class="flex items-center gap-3 bg-bg-1 border border-border rounded-card shadow-card px-5 py-4 max-w-sm mx-4">
    <span class="shrink-0 w-8 h-8 rounded-full bg-success/15 flex items-center justify-center text-success">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
        <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
    <div class="min-w-0">
      <div id="site-toast-title" class="text-text-white font-semibold text-sm">Message sent!</div>
      <div id="site-toast-message" class="text-text-muted text-xs mt-0.5"></div>
    </div>
  </div>
</div>

<script>
  let hideTimer: ReturnType<typeof setTimeout> | null = null

  function showToast(title: string, message?: string) {
    const toast = document.getElementById('site-toast')
    const titleEl = document.getElementById('site-toast-title')
    const messageEl = document.getElementById('site-toast-message')
    if (!toast || !titleEl || !messageEl) return

    titleEl.textContent = title
    messageEl.textContent = message ?? ''
    messageEl.classList.toggle('hidden', !message)

    if (hideTimer) clearTimeout(hideTimer)

    toast.classList.remove('opacity-0', '-translate-y-2', 'pointer-events-none')
    hideTimer = setTimeout(() => {
      toast.classList.add('opacity-0', '-translate-y-2', 'pointer-events-none')
    }, 3000)
  }

  // Exposed globally so any form's submit handler can call it.
  ;(window as any).showToast = showToast
</script>
