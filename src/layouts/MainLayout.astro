---
import '../styles/global.css'
import { sanityClient } from '../lib/sanity'
import { SITE_SETTINGS_QUERY } from '../lib/queries'

interface Props {
  title?:       string
  description?: string
  ogImage?:     string
  canonical?:   string
  schema?:      object | object[]   // JSON-LD schema(s)
  noindex?:     boolean
}

const settings = await sanityClient.fetch(SITE_SETTINGS_QUERY)

const {
  title       = settings?.defaultSeoTitle       ?? 'Muhammad Adnan — Professional Video Editor',
  description = settings?.defaultSeoDescription ?? 'Hire a professional video editor for YouTube, Reels, podcasts, and corporate video. Based in Pakistan, working globally.',
  ogImage     = settings?.defaultOgImage?.asset?.url ?? '/og-default.jpg',
  canonical   = Astro.url.href,
  schema,
  noindex     = false,
} = Astro.props

const ga4Id  = settings?.ga4Id
const gtmId  = settings?.gtmId
const siteName = settings?.siteName ?? 'adnan.yt'

// Normalise schema to array
const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : []
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#09090b" />

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonical} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:site_name"   content={siteName} />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- Fonts (self-hosted or Google — swap as needed) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Tag Manager (head) -->
  {gtmId && (
    <script define:vars={{ gtmId }}>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer', gtmId);
    </script>
  )}

  <!-- GA4 (fallback if no GTM) -->
  {ga4Id && !gtmId && (
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
    <script define:vars={{ ga4Id }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', ga4Id);
    </script>
  )}

  <!-- JSON-LD Schema -->
  {schemas.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}

  <!-- Extra head slot -->
  <slot name="head" />
</head>

<body class="bg-bg text-text antialiased">

  <!-- GTM noscript -->
  {gtmId && (
    <noscript>
      <iframe src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
        height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>
  )}

  <!-- ── Navigation ── -->
  <slot name="nav">
    <!-- Default nav placeholder — replace with Header.astro component -->
    <nav class="sticky top-0 z-50 bg-bg/90 backdrop-blur border-b border-border">
      <div class="container flex items-center justify-between h-16">
        <a href="/" class="text-lg font-extrabold text-text-white tracking-tight">
          adnan<span class="text-gradient">.yt</span>
        </a>
        <div class="hidden md:flex items-center gap-6 text-sm font-medium text-text-muted">
          <a href="/services" class="hover:text-text-white transition-colors">Services</a>
          <a href="/portfolio" class="hover:text-text-white transition-colors">Portfolio</a>
          <a href="/blog"      class="hover:text-text-white transition-colors">Blog</a>
          <a href="/tutorials" class="hover:text-text-white transition-colors">Tutorials</a>
          <a href="/shop"      class="hover:text-text-white transition-colors">Shop</a>
          <a href="/about"     class="hover:text-text-white transition-colors">About</a>
        </div>
        <a href="/contact" class="btn-primary text-sm">Get a Quote</a>
      </div>
    </nav>
  </slot>

  <!-- ── Page content ── -->
  <main>
    <slot />
  </main>

  <!-- ── Footer ── -->
  <slot name="footer">
    <!-- Default footer placeholder — replace with Footer.astro component -->
    <footer class="border-t border-border mt-24 py-12 text-center text-sm text-text-muted">
      <p>© {new Date().getFullYear()} adnan.yt · Professional Video Editing Services</p>
      <p class="mt-1">
        <a href="/privacy-policy" class="hover:text-text-white mx-2">Privacy</a> ·
        <a href="/affiliate-disclosure" class="hover:text-text-white mx-2">Affiliate Disclosure</a>
      </p>
    </footer>
  </slot>

  <!-- ── WhatsApp Float ── -->
  {settings?.enableWhatsapp && settings?.whatsappNumber && (
    <a
      href={`https://wa.me/${settings.whatsappNumber}?text=Hi%20Adnan,%20I%20need%20video%20editing%20help.`}
      target="_blank" rel="noopener noreferrer"
      aria-label="Chat on WhatsApp"
      class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25d366] rounded-pill flex items-center justify-center shadow-lg hover:scale-110 transition-transform"
      onclick="gtag && gtag('event','whatsapp_click',{event_category:'engagement'})"
    >
      <svg class="w-7 h-7 fill-white" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>
  )}

  <!-- ── Scripts slot ── -->
  <slot name="scripts" />

</body>
</html>
