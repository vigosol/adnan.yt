---
import MainLayout from '../layouts/MainLayout.astro'
import PricingShowcase from '../components/PricingShowcase.astro'
import Spacer from '../components/Spacer.astro'
import FAQ from '../components/FAQ.astro'
import CTA from '../components/CTA.astro'
import { fetchSanity } from '../lib/sanity'
import { PRICING_PAGE_QUERY } from '../lib/queries'
import { breadcrumbSchema } from '../lib/breadcrumbs'

const pricingPage = await fetchSanity<any>(PRICING_PAGE_QUERY)

// Pricing content is CMS-managed via the Pricing Page document — fall
// back to launch-day defaults until that content is filled in.
const packages = pricingPage?.packages?.length ? pricingPage.packages : [
  {
    title: 'Starter', price: '$99', period: '/video',
    description: 'For single videos and quick turnarounds.',
    features: ['Up to 5 min final video', '1 round of revisions', 'Basic color grading', 'Captions included', '48h turnaround'],
    featured: false,
  },
  {
    title: 'Growth', price: '$249', period: '/video',
    description: 'For creators publishing regularly.',
    features: ['Up to 15 min final video', '2 rounds of revisions', 'Color grading + sound design', 'Motion graphics titles', '24h turnaround'],
    featured: true,
  },
  {
    title: 'Agency', price: 'Custom', period: '',
    description: 'For ongoing or bulk monthly volume.',
    features: ['Dedicated editor', 'Unlimited revisions', 'Priority turnaround', 'Monthly retainer pricing'],
    featured: false,
  },
]

const packagesWithCta = packages.map((pkg: any) => ({
  ...pkg,
  ctaLabel: pkg.price === 'Custom' ? 'Get a Custom Quote' : 'Get Started',
}))

const addOns = pricingPage?.addOns?.length ? pricingPage.addOns : [
  { name: 'Custom Thumbnails', price: '$29 /thumbnail', description: 'Scroll-stopping thumbnail design with A/B variants, matched to your channel branding.' },
  { name: 'Rush Delivery', price: '+40%', description: 'Jump the queue. Guaranteed 24–48h turnaround for time-sensitive launches and trends.' },
  { name: 'Subtitles & Localization', price: '$19 /language', description: 'Accurate captions plus translated subtitle tracks to open your content to new markets.' },
  { name: 'Content Strategy Call', price: '$99 /session', description: '60-minute session on packaging, titles, and retention data — with a written action plan.' },
  { name: 'Channel Audit', price: '$149 one-off', description: "Deep review of your last 10 videos: hooks, pacing, and drop-off points, with fixes ranked by impact." },
  { name: 'Raw Footage Cleanup', price: '$49 /hour of footage', description: 'Sync, organize, and pre-cut multicam or messy footage so every future edit starts faster.' },
]

const faqs = pricingPage?.faqs?.length ? pricingPage.faqs : [
  { question: 'Do you offer discounts for bulk or monthly work?', answer: 'Yes — the Agency tier is built around ongoing monthly volume. Get in touch for custom pricing.' },
  { question: "What's included in a revision round?", answer: 'Any changes to pacing, color, music, captions, or graphics within the original project brief.' },
  { question: 'Do you require payment upfront?', answer: "Typically 50% upfront and 50% on delivery for new clients. We can discuss what works for your project." },
  { question: "What if my project doesn't fit a package?", answer: "Most projects do, but if yours is unique, just describe it in the contact form and I'll send a custom quote." },
]

// Cycled by index — matches the ServiceShowcase/ProcessSection fallback-icon
// convention, no per-add-on icon field needed in Sanity.
const ADDON_ICONS = [
  '<rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21" stroke-linecap="round" stroke-linejoin="round"/>',
  '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3" stroke-linecap="round" stroke-linejoin="round"/>',
  '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M7 15h4M13 15h4M7 11h10" stroke-linecap="round"/>',
  '<path d="M4 5h16a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H9l-5 4v-4H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z" stroke-linecap="round" stroke-linejoin="round"/>',
  '<circle cx="10.5" cy="10.5" r="6.5"/><path d="M20 20l-4.35-4.35" stroke-linecap="round"/>',
  '<path d="M3 12h4l2-7 4 14 2-7h6" stroke-linecap="round" stroke-linejoin="round"/>',
]

function cellClasses(i: number, total: number) {
  const isOverallLast = i === total - 1
  const isLastRowDesktop = i >= total - 3
  return [
    !isOverallLast && 'border-b border-border-light',
    isLastRowDesktop && 'md:border-b-0',
  ].filter(Boolean).join(' ')
}

// JSON-LD — Product/Offer schema for each fixed-price package
const numericPackages = packages.filter((p: any) => /^\$[\d,.]+$/.test(p.price))
const pricingSchema = numericPackages.map((p: any) => ({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: `${p.title} Video Editing Package`,
  description: p.description,
  offers: {
    '@type': 'Offer',
    price: p.price.replace(/[^0-9.]/g, ''),
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
  },
}))
---

<MainLayout
  title="Pricing — Video Editing Packages | adnan.yt"
  description="Transparent pricing for YouTube, Shorts, and corporate video editing. Pick a package or get a custom quote."
  schema={[...pricingSchema, breadcrumbSchema([{ name: 'Home', url: '/' }, { name: 'Pricing', url: '/pricing' }])]}
>

  <PricingShowcase
    badge="Pricing"
    heading="Simple, Transparent Pricing"
    subtitle="Pick the package that fits your workflow, or get a custom quote for something different."
    packages={packagesWithCta}
    showHeroBackground={true}
  />

  <!-- ══ ADD-ONS ════════════════════════════════════════════════════ -->
  <Spacer borderTop borderBottom />
  <section>
    <div class="container md:border-x md:border-border-light md:px-0">
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6 px-6 md:pl-[30px] md:pr-8 py-10 md:py-14">
        <div>
          <span class="inline-block border border-border-light rounded-full text-xs font-normal px-3 py-1 text-text-muted mb-4">Add-ons</span>
          <h2 class="text-4xl md:text-5xl font-bold text-text-white max-w-[800px]">
            Extras that make videos <span class="text-accent">work harder.</span>
          </h2>
        </div>
        <p class="text-text-muted text-lg max-w-sm md:pt-2">
          Stack any add-on onto a single edit or your monthly package.
        </p>
      </div>

      <div class="border-t border-border-light grid grid-cols-1 md:grid-cols-3 md:gap-x-px md:bg-border-light">
        {addOns.map((addOn: any, i: number) => (
          <div class={`p-8 bg-bg-1 ${cellClasses(i, addOns.length)}`}>
            <div class="flex items-start justify-between mb-6">
              <div class="w-11 h-11 rounded-lg bg-bg-2 flex items-center justify-center text-accent">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={ADDON_ICONS[i % ADDON_ICONS.length]} />
              </div>
              <span class="text-accent font-bold text-sm whitespace-nowrap">{addOn.price}</span>
            </div>
            <h3 class="font-bold text-text-white mb-2">{addOn.name}</h3>
            <p class="text-text-muted text-base leading-6">{addOn.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ FAQs ═══════════════════════════════════════════════════════ -->
  <Spacer borderTop />
  <section>
    <div class="container md:border-x md:border-t md:border-border-light md:px-0">
      <div class="px-6 md:pl-[30px] md:pr-8 py-10 md:py-14">
        <span class="inline-block border border-border-light rounded-full text-xs font-normal px-3 py-1 text-text-muted mb-4">FAQs</span>
        <h2 class="text-4xl md:text-5xl font-bold text-text-white max-w-[800px]">Frequently Asked Questions</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <!-- ══ CTA ════════════════════════════════════════════════════════ -->
  <CTA
    heading="Not Sure Which Package Fits?"
    subtext="Tell me about your project and I'll send a custom quote within 24 hours."
    primaryCta={{ label: 'Get a Custom Quote →', href: '/contact' }}
  />

</MainLayout>
