---
import MainLayout from '../layouts/MainLayout.astro'
import Hero from '../components/Hero.astro'
import Metrics from '../components/Metrics.astro'
import Spacer from '../components/Spacer.astro'
import AboutTeaser from '../components/AboutTeaser.astro'
import ServicesShowcase from '../components/ServicesShowcase.astro'
import PricingShowcase from '../components/PricingShowcase.astro'
import ProcessSection from '../components/ProcessSection.astro'
import TestimonialsShowcase from '../components/TestimonialsShowcase.astro'
import PortfolioCard from '../components/PortfolioCard.astro'
import BlogSection from '../components/BlogSection.astro'
import NewsletterSection from '../components/NewsletterSection.astro'
import FAQ from '../components/FAQ.astro'
import CTA from '../components/CTA.astro'
import { fetchSanity, urlFor } from '../lib/sanity'
import {
  SITE_SETTINGS_QUERY, HOME_PAGE_QUERY, SERVICES_HOMEPAGE_QUERY, TESTIMONIALS_QUERY, PORTFOLIO_LIST_QUERY,
  BLOG_HOMEPAGE_QUERY,
} from '../lib/queries'

const [settings, home, services, testimonials, portfolio, blogPosts] = await Promise.all([
  fetchSanity<any>(SITE_SETTINGS_QUERY),
  fetchSanity<any>(HOME_PAGE_QUERY),
  fetchSanity<any[]>(SERVICES_HOMEPAGE_QUERY),
  fetchSanity<any[]>(TESTIMONIALS_QUERY),
  fetchSanity<any[]>(PORTFOLIO_LIST_QUERY),
  fetchSanity<any[]>(BLOG_HOMEPAGE_QUERY),
])

// Hero / Process / FAQs / Trust Stats are CMS-managed via the Home Page
// document — fall back to launch-day defaults until that's filled in.
const hero = {
  badge: home?.hero?.badge ?? 'Remote Video Editing Partner',
  title: home?.hero?.title ?? 'I turn your footage into video people',
  highlight: home?.hero?.highlight ?? 'actually finish.',
  subtitle: home?.hero?.subtitle ??
    'Retention first editing for YouTubers, founders, and brands. You film it. I turn it into videos people watch till the last second.',
  primaryCtaLabel: home?.hero?.primaryCtaLabel ?? 'Start a Project',
  secondaryCtaLabel: home?.hero?.secondaryCtaLabel ?? 'Watch The Reel',
  reelThumbnail: home?.hero?.reelThumbnail ? urlFor(home.hero.reelThumbnail).width(1218).height(714).url() : undefined,
  reelVideoUrl: home?.hero?.reelVideoUrl,
}

const aboutTeaser = {
  quote: home?.aboutTeaser?.quote ??
    'I help creators, founders, and brands turn raw footage into premium videos that audiences actually finish watching. Through thoughtful storytelling, cinematic pacing, sound design, and motion graphics, I create content that strengthens authority, increases engagement, and helps businesses grow through video.',
  ctaLabel: home?.aboutTeaser?.ctaLabel ?? 'Read the story',
}

const servicesSection = {
  badge: home?.servicesSection?.badge ?? 'Services',
  heading: home?.servicesSection?.heading ?? 'Everything your content needs, after the record button.',
  subtitle: home?.servicesSection?.subtitle ??
    'From first cut to final export, every service is built to keep your content polished and consistent.',
  viewAllLabel: home?.servicesSection?.viewAllLabel ?? 'View all Services',
  tags: home?.servicesSection?.tags?.length ? home.servicesSection.tags : [
    'Youtube Video Editing', 'Podcast Editing', 'Youtube Shorts Editing', 'Instagram Reels Editing',
    'Tiktok Video Editing', 'Corporate Video Editing', 'Medical Video Editing', 'Real Estate Video Editing',
    'Event Video Editing', 'Interview Video Editing', 'Talking Head Video Editing', 'Social Media Video Editing',
    'Ecommerce Video Editing', 'Explainer Video Editing', 'Audio Enhancement', 'Video Color Grading',
    'Video Repurposing', 'Subtitle and Caption Editing',
  ],
}

const processSection = {
  badge: home?.processSection?.badge ?? 'How It Works',
  heading: home?.processSection?.heading ?? 'From raw footage to finished video, in four steps.',
  highlightPhrase: home?.processSection?.highlightPhrase ?? 'finished video',
  subtitle: home?.processSection?.subtitle ??
    'A simple, transparent process. You stay focused on filming — I handle everything after the record button.',
}

const processSteps = home?.process?.length ? home.process : [
  { title: 'Share your footage', description: 'Upload raw clips via Drive or Dropbox with a short brief on your goals and style.' },
  { title: 'We cut & design',    description: 'Retention-first editing, sound design, motion graphics, and color grading applied to every frame.' },
  { title: 'Review & refine',    description: 'Leave time-stamped comments and get revisions until the edit feels exactly right.' },
  { title: 'Publish & grow',     description: 'Receive the final video, thumbnail posters, and platform-ready exports within 24-48h.' },
]

const testimonialsSection = {
  badge: home?.testimonialsSection?.badge ?? 'Testimonials',
  heading: home?.testimonialsSection?.heading ?? 'Creators and brands who trust the process.',
  subtitle: home?.testimonialsSection?.subtitle ?? 'Real feedback from real clients — see why they keep coming back.',
  viewAllLabel: home?.testimonialsSection?.viewAllLabel ?? 'View all Reviews',
}

const blogSection = {
  badge: home?.blogSection?.badge ?? 'Blog',
  heading: home?.blogSection?.heading ?? 'Insights on editing & growth.',
  highlightPhrase: home?.blogSection?.highlightPhrase ?? '& growth.',
  subtitle: home?.blogSection?.subtitle ??
    'Practical breakdowns on editing, retention, and growth — drawn from real client projects.',
  viewAllLabel: home?.blogSection?.viewAllLabel ?? 'View all Posts',
}

const newsletterSection = {
  badge: home?.newsletterSection?.badge ?? 'Newsletter',
  heading: home?.newsletterSection?.heading ?? 'Sharper videos, straight to your inbox.',
  highlightPhrase: home?.newsletterSection?.highlightPhrase ?? 'your inbox.',
  subtitle: home?.newsletterSection?.subtitle ??
    'One email a month with editing tips, retention insights, and behind-the-scenes breakdowns of real projects.',
  placeholder: home?.newsletterSection?.placeholder ?? 'Enter your email address',
  buttonLabel: home?.newsletterSection?.buttonLabel ?? 'Subscribe →',
  disclaimer: home?.newsletterSection?.disclaimer ?? 'No spam, unsubscribe anytime.',
}

const ctaSection = {
  badge: home?.ctaSection?.badge ?? '🔥 Limited slots each month',
  heading: home?.ctaSection?.heading ?? 'Ready to Elevate Your Videos?',
  highlightPhrase: home?.ctaSection?.highlightPhrase ?? 'Your Videos?',
  subtext: home?.ctaSection?.subtext ?? "Let's talk about your project. Free quote, no obligation.",
  primaryCtaLabel: home?.ctaSection?.primaryCtaLabel ?? 'Get Your Free Quote →',
  secondaryCtaLabel: home?.ctaSection?.secondaryCtaLabel ?? 'View Pricing',
}

const faqs = home?.faqs?.length ? home.faqs : [
  { question: 'How fast is turnaround?', answer: 'Most projects are delivered within 24–48 hours, depending on length and complexity.' },
  { question: 'How many revisions are included?', answer: 'One round of revisions is included with every project. Additional rounds can be added on request.' },
  { question: 'What file formats do you accept?', answer: 'Any common format — MP4, MOV, or raw camera footage. Share it via Google Drive or WeTransfer.' },
  { question: 'Do you sign NDAs?', answer: 'Yes — happy to sign an NDA before you share any footage, just ask.' },
]

const trustStats = home?.trustStats?.length ? home.trustStats : [
  { val: '400+',   label: 'Projects delivered', description: 'Delivered high-performing videos across multiple industries and content formats.' },
  { val: '60+',    label: 'Creators & Brands',  description: 'Trusted by creators, startups, businesses, and growing personal brands worldwide.' },
  { val: '24-72h', label: 'Average Turaround',  description: 'Fast delivery without compromising storytelling, quality, or viewer retention.' },
  { val: '4.9',    label: 'Client Rating',      description: 'Consistently rated highly for communication, quality, and reliability.' },
]

const pricingSection = {
  badge: home?.pricingSection?.badge ?? 'Pricing',
  heading: home?.pricingSection?.heading ?? 'Choose the best package for you',
  subtitle: home?.pricingSection?.subtitle ?? 'Transparent pricing. No hidden costs. Just results.',
  packages: home?.pricingSection?.packages?.length ? home.pricingSection.packages : [
    {
      title: 'Single Edit', price: '199', period: 'video',
      description: 'A single short or long form video edit',
      ctaLabel: 'Book a Call',
      featured: false,
      features: [
        'One fully-edited video (short or long-form)', 'Fast 3-5 day turnaround', 'Captions/subtitles included',
        'Color grading & sound mixing', '2 round of revisions', 'Thumbnail poster included',
        'Short up to 60 sec, Long up to 2 mins',
      ],
    },
    {
      title: 'Regular Edit', price: '1999', period: 'month',
      description: 'Growing brands aiming for post regularly',
      ctaLabel: 'Subscribe Now',
      featured: true,
      features: [
        'Up to 15 edited videos per month', 'Priority 2-3 day turnaround', 'Unlimited revisions',
        'Regular updates', 'Strategy support for content', 'Thumbnail poster included', 'One video at a time',
      ],
    },
  ],
  helpPanel: {
    block1Heading: home?.pricingSection?.helpPanel?.block1Heading ?? "Still can't decide?",
    block1Subtext: home?.pricingSection?.helpPanel?.block1Subtext ?? "Let's figure out what you need",
    block1CtaLabel: home?.pricingSection?.helpPanel?.block1CtaLabel ?? "Let's Talk",
    block2Heading: home?.pricingSection?.helpPanel?.block2Heading ?? 'Get a free quote',
    block2Subtext: home?.pricingSection?.helpPanel?.block2Subtext ?? 'Free quote, no obligation.',
    block2CtaLabel: home?.pricingSection?.helpPanel?.block2CtaLabel ?? 'Get Quote',
  },
}

// JSON-LD — Organization schema
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'adnan.yt',
  url: 'https://adnan.yt',
  logo: 'https://adnan.yt/logo.png',
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: settings?.phone ?? '',
    contactType: 'customer service',
  },
  sameAs: [
    settings?.socialLinks?.youtube,
    settings?.socialLinks?.instagram,
    settings?.socialLinks?.linkedin,
  ].filter(Boolean),
}

// JSON-LD — FAQPage schema
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f: any) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
}
---

<MainLayout
  title="Muhammad Adnan — Professional Video Editing Services | adnan.yt"
  description="Professional YouTube, Reels, podcast & corporate video editing. Fast turnaround, competitive pricing. Get your free quote today."
  schema={[orgSchema, faqSchema]}
>

  <!-- ══ HERO ══════════════════════════════════════════════════════ -->
  <Hero
    badge={hero.badge}
    title={hero.title}
    highlight={hero.highlight}
    subtitle={hero.subtitle}
    primaryCta={{ label: hero.primaryCtaLabel, href: '/contact' }}
    secondaryCta={{ label: hero.secondaryCtaLabel, href: '#reel' }}
    reelThumbnail={hero.reelThumbnail}
    reelVideoUrl={hero.reelVideoUrl}
  />

  <!-- ══ ABOUT TEASER ═══════════════════════════════════════════════ -->
  <Spacer />
  <AboutTeaser quote={aboutTeaser.quote} ctaLabel={aboutTeaser.ctaLabel} />

  <!-- ══ METRICS ═══════════════════════════════════════════════════ -->
  <Metrics stats={trustStats} />
  <Spacer />

  <!-- ══ SERVICES ═══════════════════════════════════════════════════ -->
  <ServicesShowcase
    badge={servicesSection.badge}
    heading={servicesSection.heading}
    subtitle={servicesSection.subtitle}
    viewAllLabel={servicesSection.viewAllLabel}
    services={services ?? []}
    tags={servicesSection.tags}
  />

  <!-- ══ FEATURED WORK ═════════════════════════════════════════════ -->
  <Spacer borderTop borderBottom />
  <section>
    <div class="container md:border-x md:border-border-light md:px-0">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 px-6 md:pl-[30px] md:pr-8 py-10 md:py-14">
        <div>
          <span class="inline-block border border-border-light rounded-full text-xs font-normal px-3 py-1 text-text-muted mb-4">Portfolio</span>
          <h2 class="text-4xl md:text-5xl font-bold text-text-white mb-3 max-w-[800px]">
            Work that keeps people <span class="text-accent">watching.</span>
          </h2>
          <p class="text-text-muted text-lg max-w-xl">
            A selection of recent edits across long form, shorts, motion graphics, and commercials — each one built for retention.
          </p>
        </div>
        <a href="/portfolio" class="group shrink-0 inline-flex items-center gap-2 border-b border-current pb-1 text-text-white font-medium">
          View all Work
          <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>

      {portfolio?.length ? (
        <div class="border-t border-border-light grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5 px-6 md:px-[30px] pt-8 pb-10 md:pb-14">
          {portfolio.slice(0, 8).map((item: any) => (
            <PortfolioCard item={item} />
          ))}
        </div>
      ) : (
        <p class="text-text-muted text-sm border-t border-border-light px-6 md:px-[30px] py-10">
          Portfolio items will appear here once added in Sanity Studio.
        </p>
      )}
    </div>
  </section>

  <!-- ══ PRICING ════════════════════════════════════════════════════ -->
  <Spacer borderTop borderBottom />
  <PricingShowcase
    badge={pricingSection.badge}
    heading={pricingSection.heading}
    subtitle={pricingSection.subtitle}
    packages={pricingSection.packages}
    helpPanel={pricingSection.helpPanel}
  />

  <!-- ══ PROCESS ════════════════════════════════════════════════════ -->
  <Spacer borderTop borderBottom />
  <ProcessSection
    badge={processSection.badge}
    heading={processSection.heading}
    highlightPhrase={processSection.highlightPhrase}
    subtitle={processSection.subtitle}
    steps={processSteps}
  />

  <!-- ══ TESTIMONIALS ═══════════════════════════════════════════════ -->
  <Spacer borderTop borderBottom />
  <TestimonialsShowcase
    badge={testimonialsSection.badge}
    heading={testimonialsSection.heading}
    subtitle={testimonialsSection.subtitle}
    viewAllLabel={testimonialsSection.viewAllLabel}
    testimonials={testimonials ?? []}
  />

  <!-- ══ FAQs ═══════════════════════════════════════════════════════ -->
  <Spacer borderTop />
  <section>
    <div class="container md:border-x md:border-t md:border-border-light md:px-0">
      <div class="px-6 md:pl-[30px] md:pr-8 py-10 md:py-14">
        <span class="inline-block border border-border-light rounded-full text-xs font-normal px-3 py-1 text-text-muted mb-4">FAQs</span>
        <h2 class="text-4xl md:text-5xl font-bold text-text-white max-w-[800px]">Frequently Asked Questions</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <!-- ══ BLOG ═══════════════════════════════════════════════════════ -->
  <Spacer borderTop borderBottom />
  <BlogSection
    badge={blogSection.badge}
    heading={blogSection.heading}
    highlightPhrase={blogSection.highlightPhrase}
    subtitle={blogSection.subtitle}
    viewAllLabel={blogSection.viewAllLabel}
    posts={blogPosts ?? []}
  />

  <!-- ══ NEWSLETTER ═════════════════════════════════════════════════ -->
  <Spacer borderTop borderBottom />
  <NewsletterSection
    badge={newsletterSection.badge}
    heading={newsletterSection.heading}
    highlightPhrase={newsletterSection.highlightPhrase}
    subtitle={newsletterSection.subtitle}
    placeholder={newsletterSection.placeholder}
    buttonLabel={newsletterSection.buttonLabel}
    disclaimer={newsletterSection.disclaimer}
  />

  <!-- ══ CTA BANNER ════════════════════════════════════════════════ -->
  <CTA
    badge={ctaSection.badge}
    heading={ctaSection.heading}
    highlightPhrase={ctaSection.highlightPhrase}
    subtext={ctaSection.subtext}
    primaryCta={{ label: ctaSection.primaryCtaLabel, href: '/contact' }}
    secondaryCta={{ label: ctaSection.secondaryCtaLabel, href: '/pricing' }}
  />

</MainLayout>