---
import fs from 'node:fs'
import path from 'node:path'

interface Service {
  title: string
  shortDescription?: string
  slug: { current: string } | string
  iconImageUrl?: string
}
interface Props {
  badge?: string
  heading?: string
  subtitle?: string
  viewAllLabel?: string
  services: Service[]
  tags: string[]
}
const {
  badge = 'Services',
  heading = 'Everything your content needs, after the record button.',
  subtitle,
  viewAllLabel = 'View all Services',
  services,
  tags,
} = Astro.props as Props

// Fallback line-art icon assets from /public (used when a service has no
// iconImage set in Sanity) — recolored to currentColor at build time so the
// wrapper controls opacity/color for the default + hover states.
const ICON_FILES = ['short-form-editing', 'long-form-editing', 'motion-graphics', 'color-grading', 'audio-enhancement', 'video-clipping']

function loadIcon(filename: string): string | null {
  try {
    const filePath = path.join(process.cwd(), 'public', `${filename}.svg`)
    let svg = fs.readFileSync(filePath, 'utf-8')
    svg = svg.replace(/fill="white"/gi, 'fill="currentColor"')
    svg = svg.replace(/\s*opacity="0\.7"/gi, '')
    svg = svg.replace('<svg ', '<svg class="w-full h-full" ')
    return svg
  } catch {
    return null
  }
}
const fallbackIcons = ICON_FILES.map(loadIcon)

function chunk(arr: string[], n: number) {
  const size = Math.ceil(arr.length / n)
  return Array.from({ length: n }, (_, i) => arr.slice(i * size, i * size + size)).filter(r => r.length)
}
const tagRows = chunk(tags, 3)

// Row dividers (top/bottom) use normal borders — fine, since each cell's
// top/bottom edge is only ever shared with the cell directly above/below in
// the same column, no cross-column rounding involved.
//
// Column dividers (between col1|col2 and col2|col3) do NOT use borders: with
// a 1280px-ish container split into three `1fr` tracks, the width per column
// isn't a whole number, so adjacent cells' borders can land a sub-pixel apart
// and leave a hairline gap showing the page background through. Instead the
// grid itself gets `gap-x-px` + a divider-colored background — a real layout
// gutter is pixel-exact by construction, so there's nothing to misalign.
function cellBorderClass(i: number) {
  const row = Math.floor(i / 3)
  const classes = ['md:border-b', 'md:border-b-border-light']
  if (row === 0) classes.push('md:border-t', 'md:border-t-border-light')

  // Complete the outer frame on the left-column / right-column cells.
  if (i === 0 || i === 3) classes.push('md:border-l', 'md:border-l-border-light')
  if (i === 2 || i === 5) classes.push('md:border-r', 'md:border-r-border-light')

  return classes.join(' ')
}
---

<section>
  <div class="container md:border-x md:border-border-light md:px-0">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 px-6 md:pl-[30px] md:pr-8 py-10 md:py-14">
      <div>
        <span class="inline-block border border-border-light text-text-muted text-xs font-normal uppercase tracking-wide px-3 py-1.5 rounded-full mb-4">
          {badge}
        </span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-text-white leading-tight max-w-[800px]">
          {heading}
        </h2>
        {subtitle && <p class="text-text-muted text-base md:text-lg max-w-xl mt-4">{subtitle}</p>}
      </div>
      <a
        href="/services"
        class="group shrink-0 inline-flex items-center gap-2 border-b border-current pb-1 text-text-white font-medium bg-transparent"
      >
        {viewAllLabel}
        <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>

  {services?.length > 0 && (
    <div>
      <div class="container md:px-0">
        <div class="grid grid-cols-1 md:grid-cols-3 md:gap-x-px md:bg-border-light">
          {services.map((service, i) => {
            const slug = typeof service.slug === 'string' ? service.slug : service.slug?.current
            const fallbackIcon = fallbackIcons[i % fallbackIcons.length]
            return (
              <a
                href={slug ? `/services/${slug}` : '/services'}
                class={`group flex flex-col justify-center bg-bg-1 p-8 min-h-[320px] transition-colors hover:bg-bg-2 ${cellBorderClass(i)}`}
              >
                {service.iconImageUrl ? (
                  <img src={service.iconImageUrl} alt="" class="w-10 h-10 shrink-0 object-contain" />
                ) : fallbackIcon ? (
                  <div class="w-10 h-10 shrink-0 text-accent transition-colors" set:html={fallbackIcon} />
                ) : null}
                <h3 class="text-text-white group-hover:text-accent-light font-bold text-xl mt-6 mb-3 transition-colors">
                  {service.title}
                </h3>
                {service.shortDescription && (
                  <p class="text-text-muted text-base leading-6 min-h-[72px] transition-colors">
                    {service.shortDescription}
                  </p>
                )}
                <span class="mt-4 inline-flex items-center gap-1.5 self-start border-b-2 border-current text-accent text-sm font-medium pb-0.5 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                  Learn more
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </a>
            )
          })}
        </div>
      </div>
    </div>
  )}

  {tagRows.length > 0 && (
    <div>
      <div class="container md:border-x md:border-border-light md:px-0 py-10 md:py-14 flex flex-col gap-4">
        {tagRows.map((row, i) => (
          <div class="marquee-row overflow-hidden">
            <div class={`marquee-track ${i % 2 === 0 ? 'marquee-left' : 'marquee-right'}`}>
              {[...row, ...row, ...row, ...row, ...row, ...row].map(tag => (
                <span class="tag-pill">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  )}
</section>

<style>
  .marquee-track {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: max-content;
  }
  .marquee-left  { animation: marquee-left 70s linear infinite; }
  .marquee-right { animation: marquee-right 70s linear infinite; }
  .marquee-row:hover .marquee-track { animation-play-state: paused; }

  @keyframes marquee-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-16.6667%); }
  }
  @keyframes marquee-right {
    from { transform: translateX(-16.6667%); }
    to   { transform: translateX(0); }
  }

  .tag-pill {
    flex-shrink: 0;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    border-radius: 9999px;
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
  }
</style>
