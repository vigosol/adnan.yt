---
import MainLayout from '../layouts/MainLayout.astro'
import TutorialGridCard from '../components/TutorialGridCard.astro'
import PageHeroBackground from '../components/PageHeroBackground.astro'
import Spacer from '../components/Spacer.astro'
import { fetchSanity } from '../lib/sanity'
import { TUTORIAL_LIST_QUERY } from '../lib/queries'
import { breadcrumbSchema } from '../lib/breadcrumbs'

const tutorials = await fetchSanity<any[]>(TUTORIAL_LIST_QUERY, { from: 0, to: 23 })

const categories = ['All', ...new Set((tutorials ?? []).map((t: any) => t.category).filter(Boolean))]
---

<MainLayout
  title="Tutorials — Learn Video Editing | adnan.yt"
  description="Step-by-step video editing tutorials for Premiere Pro, After Effects, DaVinci Resolve, and CapCut."
  schema={breadcrumbSchema([{ name: 'Home', url: '/' }, { name: 'Tutorials', url: '/tutorials' }])}
>

  <section class="relative overflow-hidden">
    <PageHeroBackground />
    <div class="container md:border-x md:border-border-light md:px-0 min-h-[300px] md:min-h-[400px] flex flex-col justify-center">
      <div class="px-6 md:pl-[30px] md:pr-8 py-10 md:py-14">
        <span class="inline-block border border-border-light rounded-full text-xs font-normal px-3 py-1 text-text-muted mb-4">Tutorials</span>
        <h1 class="text-4xl md:text-5xl font-bold text-text-white mb-3 tracking-tight max-w-[800px]">
          Video Editing <span class="text-accent">Tutorials</span>
        </h1>
        <p class="text-text-muted text-lg max-w-[800px]">
          Step-by-step guides to help you edit faster and better.
        </p>
      </div>
    </div>
  </section>

  <Spacer borderTop borderBottom />
  <section class="py-20">
    <div class="container">
      {tutorials?.length ? (
        <>
          <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
            {categories.length > 2 && (
              <div class="flex flex-wrap gap-2" id="tutorial-filters">
                {categories.map((c, i) => (
                  <button
                    type="button"
                    data-filter={c}
                    class={`px-4 py-2 rounded-[4px] text-sm font-medium border border-border transition-colors ${i === 0 ? 'bg-accent-dark text-white border-accent-dark' : 'text-text-muted hover:text-text-white hover:border-border-light'}`}
                  >
                    {c}
                  </button>
                ))}
              </div>
            )}

            <p class="text-text-muted text-sm shrink-0" id="tutorial-count">{tutorials.length} tutorials</p>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5" id="tutorial-grid">
            {tutorials.map((t: any) => (
              <div data-category={t.category ?? 'All'}>
                <TutorialGridCard tutorial={t} />
              </div>
            ))}
          </div>
        </>
      ) : (
        <p class="text-text-muted text-center">
          Tutorials will appear here once published in Sanity Studio.
        </p>
      )}
    </div>
  </section>

</MainLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('#tutorial-filters [data-filter]')
  const cards = document.querySelectorAll<HTMLElement>('#tutorial-grid [data-category]')
  const countEl = document.getElementById('tutorial-count')

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter

      filterBtns.forEach(b => {
        b.classList.remove('bg-accent-dark', 'text-white', 'border-accent-dark')
        b.classList.add('text-text-muted', 'hover:text-text-white', 'hover:border-border-light')
      })
      btn.classList.add('bg-accent-dark', 'text-white', 'border-accent-dark')
      btn.classList.remove('text-text-muted', 'hover:text-text-white', 'hover:border-border-light')

      let visibleCount = 0
      cards.forEach(card => {
        const show = filter === 'All' || card.dataset.category === filter
        card.classList.toggle('hidden', !show)
        if (show) visibleCount++
      })

      if (countEl) countEl.textContent = `${visibleCount} tutorial${visibleCount === 1 ? '' : 's'}`
    })
  })
</script>
