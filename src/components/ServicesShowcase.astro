---
import ServiceGridCard from './ServiceGridCard.astro'
import { fallbackServiceIcons, serviceCellBorderClass } from '../lib/serviceIcons'

interface Service {
  title: string
  shortDescription?: string
  slug: { current: string } | string
  iconImageUrl?: string
}
interface Props {
  badge?: string
  heading?: string
  highlightPhrase?: string
  subtitle?: string
  viewAllLabel?: string
  services: Service[]
  tags: string[]
}
const {
  badge = 'Services',
  heading = 'Everything your content needs, after the record button.',
  highlightPhrase = 'after the record button.',
  subtitle,
  viewAllLabel = 'View all Services',
  services,
  tags,
} = Astro.props as Props

// Split the heading around the highlighted phrase so it can render in accent
// color while the rest stays default — natural wrap only, no forced <br>.
function splitHeading(text: string, phrase?: string) {
  if (!phrase) return [{ text, accent: false }]
  const idx = text.indexOf(phrase)
  if (idx === -1) return [{ text, accent: false }]
  return [
    { text: text.slice(0, idx), accent: false },
    { text: text.slice(idx, idx + phrase.length), accent: true },
    { text: text.slice(idx + phrase.length), accent: false },
  ].filter(part => part.text.length > 0)
}
const headingParts = splitHeading(heading, highlightPhrase)

function chunk(arr: string[], n: number) {
  const size = Math.ceil(arr.length / n)
  return Array.from({ length: n }, (_, i) => arr.slice(i * size, i * size + size)).filter(r => r.length)
}
const tagRows = chunk(tags, 3)
---

<section>
  <div class="container md:border-x md:border-border-light md:px-0">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 px-6 md:pl-[30px] md:pr-8 py-10 md:py-14">
      <div>
        <span class="inline-block border border-border-light text-text-muted text-xs font-normal uppercase tracking-wide px-3 py-1.5 rounded-full mb-4">
          {badge}
        </span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-text-white leading-tight tracking-tight max-w-[800px]">
          {headingParts.map(part => part.accent ? <span class="text-accent">{part.text}</span> : part.text)}
        </h2>
        {subtitle && <p class="text-text-muted text-base md:text-lg max-w-xl mt-4">{subtitle}</p>}
      </div>
      <a
        href="/services"
        class="group shrink-0 inline-flex items-center gap-2 border-b border-current pb-1 text-text-white font-medium bg-transparent"
      >
        {viewAllLabel}
        <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>

  {services?.length > 0 && (
    <div>
      <div class="container md:px-0">
        <div class="grid grid-cols-1 md:grid-cols-3 md:gap-x-px md:bg-border-light">
          {services.map((service, i) => (
            <ServiceGridCard
              service={service}
              fallbackIcon={fallbackServiceIcons[i % fallbackServiceIcons.length]}
              cellClass={serviceCellBorderClass(i)}
            />
          ))}
        </div>
      </div>
    </div>
  )}

  {tagRows.length > 0 && (
    <div>
      <div class="container md:border-x md:border-border-light md:px-0 py-10 md:py-14 flex flex-col gap-4">
        {tagRows.map((row, i) => (
          <div class="marquee-row overflow-hidden">
            <div class={`marquee-track ${i % 2 === 0 ? 'marquee-left' : 'marquee-right'}`}>
              {[...row, ...row, ...row, ...row, ...row, ...row].map(tag => (
                <span class="tag-pill">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  )}
</section>

<style>
  .marquee-track {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: max-content;
  }
  .marquee-left  { animation: marquee-left 70s linear infinite; }
  .marquee-right { animation: marquee-right 70s linear infinite; }
  .marquee-row:hover .marquee-track { animation-play-state: paused; }

  @keyframes marquee-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-16.6667%); }
  }
  @keyframes marquee-right {
    from { transform: translateX(-16.6667%); }
    to   { transform: translateX(0); }
  }

  .tag-pill {
    flex-shrink: 0;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    border-radius: 9999px;
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
  }
</style>
