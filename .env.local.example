# ─────────────────────────────────────────────────────────────────
# adnan.yt — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git (it's in .gitignore by default).
# ─────────────────────────────────────────────────────────────────

# ── Sanity (public — safe to expose in frontend) ─────────────────
# Find these at: https://www.sanity.io/manage → your project
PUBLIC_SANITY_PROJECT_ID=youridcode
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2024-01-01

# ── Sanity Write Token (SERVER ONLY — never PUBLIC_) ─────────────
# Get from: sanity.io/manage → API → Tokens → Add API token (Editor role)
SANITY_WRITE_TOKEN=sk....

# ── Site URL ──────────────────────────────────────────────────────
PUBLIC_SITE_URL=yoursiteurl
# Use this for local dev:
# PUBLIC_SITE_URL=http://localhost:4321

# ── YouTube Data API v3 (Phase 18) ───────────────────────────────
# Enable at: console.cloud.google.com → APIs → YouTube Data API v3
# Create an API key under Credentials, restrict to YouTube Data API v3
YOUTUBE_API_KEY=AIza...

# ── Cron Job Secret (Phase 18) ───────────────────────────────────
# Generate with: openssl rand -hex 32
# This protects your /api/sync-views endpoint
CRON_SECRET=your_random_secret_here

# ── Email (for contact form — using Resend) ───────────────────────
# Sign up at: https://resend.com — free up to 3000 emails/month
RESEND_API_KEY=re_...
ADMIN_EMAIL=youremailid

# ─────────────────────────────────────────────────────────────────
# Vercel environment variables — add these in the Vercel dashboard:
# Settings → Environment Variables → add each one above
# ─────────────────────────────────────────────────────────────────
