---
interface Props {
  testimonial: {
    quote: string
    rating?: number
    avatar?: string
    name: string
    company?: string
  }
}
const { testimonial: t } = Astro.props as Props
---

<div class="card">
  <div class="flex items-center gap-1 text-gold mb-3">
    {'★'.repeat(t.rating ?? 5)}
  </div>
  <p class="text-text-muted text-base leading-6 mb-4">"{t.quote}"</p>
  <div class="flex items-center gap-3">
    {t.avatar && <img src={t.avatar} alt={t.name} class="w-9 h-9 rounded-full object-cover" />}
    <div>
      <div class="font-semibold text-text-white text-sm">{t.name}</div>
      {t.company && <div class="text-text-muted text-xs">{t.company}</div>}
    </div>
  </div>
</div>
