---
interface CtaLink {
  label: string
  href: string
}
interface Props {
  heading: string
  subtext?: string
  primaryCta?: CtaLink
  secondaryCta?: CtaLink
}
const {
  heading,
  subtext,
  primaryCta = { label: 'Get Your Free Quote →', href: '/contact' },
  secondaryCta,
} = Astro.props as Props
---

<section class="py-24 border-t border-border">
  <div class="container text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-black text-text-white mb-4">{heading}</h2>
      {subtext && <p class="text-text-muted mb-8">{subtext}</p>}
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        {primaryCta && (
          <a href={primaryCta.href} class="btn-primary text-base px-8 py-4">{primaryCta.label}</a>
        )}
        {secondaryCta && (
          <a href={secondaryCta.href} class="btn-secondary text-base px-8 py-4">{secondaryCta.label}</a>
        )}
      </div>
    </div>
  </div>
</section>
