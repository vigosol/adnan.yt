---
import { fetchSanity } from '../lib/sanity'
import { SERVICES_LIST_QUERY } from '../lib/queries'
import ThemeToggle from './ThemeToggle.astro'

const services = await fetchSanity<any[]>(SERVICES_LIST_QUERY).catch(() => [])

const navLinks = [
  { href: '/portfolio',  label: 'Portfolio' },
  { href: '/pricing',    label: 'Pricing' },
  { href: '/about',      label: 'About' },
  { href: '/blog',       label: 'Blog' },
  { href: '/tutorials',  label: 'Tutorials' },
  { href: '/shop',       label: 'Shop' },
]
---

<header class="sticky top-0 z-50 bg-bg/95 backdrop-blur-sm border-b border-border-light">
  <div class="container md:border-x md:border-border-light flex items-center gap-10 h-16">

    <!-- Logo — fixed 180px column, swaps for dark mode -->
    <a href="/" class="shrink-0 flex items-center" style="width:180px">
      <img src="/logo.svg"       alt="adnan.yt" class="logo-light h-8 w-auto" />
      <img src="/logo-white.svg" alt="adnan.yt" class="logo-dark  h-8 w-auto" />
    </a>

    <!-- Nav — flex-1, centered, 32px gaps, 18px font -->
    <nav class="hidden md:flex flex-1 items-center justify-center gap-8 text-[18px] font-medium text-text-muted" aria-label="Main">
      <!-- Services dropdown -->
      <div class="relative group">
        <button
          class="flex items-center gap-1.5 hover:text-text-white transition-colors py-1"
          aria-haspopup="true"
        >
          Services
          <svg class="w-4 h-4 transition-transform duration-150 group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <div class="absolute left-0 top-full pt-3 invisible opacity-0 translate-y-1 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-150">
          <div class="w-64 card !p-2 shadow-card">
            {services?.length ? services.map((s: any) => (
              <a
                href={`/services/${s.slug.current}`}
                class="flex items-center gap-3 px-3 py-2 rounded-btn hover:bg-bg-2 text-text hover:text-text-white transition-colors"
              >
                <span>{s.icon ?? '🎬'}</span>
                <span>{s.title}</span>
              </a>
            )) : (
              <p class="px-3 py-2 text-text-muted text-sm">Add services in Sanity Studio.</p>
            )}
            <a href="/services" class="block px-3 py-2 mt-1 border-t border-border text-accent text-sm font-semibold">
              View all services →
            </a>
          </div>
        </div>
      </div>

      {navLinks.map(link => (
        <a href={link.href} class="hover:text-text-white transition-colors">{link.label}</a>
      ))}
    </nav>

    <!-- Actions — fixed 180px column, right-aligned, 32px gap -->
    <div class="hidden md:flex items-center justify-end gap-8 shrink-0" style="width:180px">
      <ThemeToggle />
      <a href="/contact" class="btn-dark">Start a Project</a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden ml-auto flex items-center justify-center w-11 h-11 text-text-white"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="icon-open" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-bg">
    <div class="container py-4 flex flex-col gap-1 text-[18px] font-medium">
      <a href="/services" class="px-2 py-2.5 rounded-btn hover:bg-bg-2 text-text-white">Services</a>
      {services?.slice(0, 5).map((s: any) => (
        <a href={`/services/${s.slug.current}`} class="px-4 py-2.5 rounded-btn hover:bg-bg-2 text-text-muted text-sm">
          {s.title}
        </a>
      ))}
      {navLinks.map(link => (
        <a href={link.href} class="px-2 py-2.5 rounded-btn hover:bg-bg-2 text-text-white">{link.label}</a>
      ))}
      <div class="flex items-center justify-between px-2 py-2.5">
        <span class="text-text-white">Theme</span>
        <ThemeToggle />
      </div>
      <a href="/contact" class="btn-dark text-center mt-1">Start a Project</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  const iconOpen = document.getElementById('icon-open')
  const iconClose = document.getElementById('icon-close')

  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden')
    btn.setAttribute('aria-expanded', String(!isHidden))
    iconOpen?.classList.toggle('hidden')
    iconClose?.classList.toggle('hidden')
  })
</script>
