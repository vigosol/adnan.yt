---
import { excerpt } from '../lib/text'

interface Post {
  title: string
  slug: { current: string } | string
  publishedAt?: string
  category?: string
  bodyText?: string
  thumbnail?: string
}
interface Props {
  badge?: string
  heading?: string
  highlightPhrase?: string
  subtitle?: string
  viewAllLabel?: string
  posts: Post[]
}
const {
  badge = 'Blog',
  heading = 'Insights on editing & growth.',
  highlightPhrase = '& growth.',
  subtitle,
  viewAllLabel = 'View all Posts',
  posts,
} = Astro.props as Props

// Split the heading around the highlighted phrase so it can render in accent
// color while the rest stays default — natural wrap only, no forced <br>.
function splitHeading(text: string, phrase?: string) {
  if (!phrase) return [{ text, accent: false }]
  const idx = text.indexOf(phrase)
  if (idx === -1) return [{ text, accent: false }]
  return [
    { text: text.slice(0, idx), accent: false },
    { text: text.slice(idx, idx + phrase.length), accent: true },
    { text: text.slice(idx + phrase.length), accent: false },
  ].filter(part => part.text.length > 0)
}
const headingParts = splitHeading(heading, highlightPhrase)

const WORDS_PER_MINUTE = 200
function readingTime(bodyText?: string) {
  const words = bodyText?.trim().split(/\s+/).filter(Boolean).length ?? 0
  return Math.max(1, Math.round(words / WORDS_PER_MINUTE))
}
---

<section>
  <div class="container md:border-x md:border-border-light md:px-0">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 px-6 md:pl-[30px] md:pr-8 py-10 md:py-14">
      <div>
        <span class="inline-block border border-border-light rounded-full text-xs font-normal px-3 py-1 text-text-muted mb-4">{badge}</span>
        <h2 class="text-4xl md:text-5xl font-bold text-text-white max-w-[800px]">
          {headingParts.map(part => part.accent ? <span class="text-accent">{part.text}</span> : part.text)}
        </h2>
        {subtitle && <p class="text-text-muted text-lg max-w-xl mt-3">{subtitle}</p>}
      </div>
      <a href="/blog" class="group shrink-0 inline-flex items-center gap-2 border-b border-current pb-1 text-text-white font-medium">
        {viewAllLabel}
        <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>

    {posts?.length > 0 && (
      <div class="border-t border-border-light grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5 px-6 md:px-[30px] pt-8 pb-10 md:pb-14">
        {posts.map(post => {
          const slug = typeof post.slug === 'string' ? post.slug : post.slug.current
          const date = post.publishedAt
            ? new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
            : null
          return (
            <a href={`/blog/${slug}`} class="group block border border-border-light hover:border-border transition-colors">
              <div class="aspect-video overflow-hidden bg-bg-2">
                {post.thumbnail ? (
                  <img
                    src={post.thumbnail} alt={post.title} loading="lazy"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-4xl">📝</div>
                )}
              </div>
              <div class="p-4">
                <div class="flex items-center gap-2 text-xs text-text-muted mb-2">
                  {date && <span>{date}</span>}
                  {date && <span>&middot;</span>}
                  <span>{readingTime(post.bodyText)} min read</span>
                </div>
                <h3 class="text-text-white font-bold mb-2 leading-6 group-hover:text-accent-light transition-colors">
                  {post.title}
                </h3>
                {excerpt(post.bodyText) && (
                  <p class="text-text-muted text-base leading-6 line-clamp-2 mb-3">{excerpt(post.bodyText)}</p>
                )}
                <span class="inline-flex items-center gap-1.5 text-accent text-sm font-semibold">
                  Read More
                  <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </div>
            </a>
          )
        })}
      </div>
    )}
  </div>
</section>
