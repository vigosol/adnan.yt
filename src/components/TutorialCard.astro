---
import { excerpt } from '../lib/text'

interface Props {
  tutorial: {
    title: string
    slug: { current: string } | string
    publishedAt?: string
    category?: string
    difficulty?: string
    bodyText?: string
    thumbnail?: string
    youtubeVideoId?: string
  }
}
const { tutorial: t } = Astro.props as Props
const slug = typeof t.slug === 'string' ? t.slug : t.slug.current
---

<a href={`/tutorials/${slug}`} class="card-hover group !p-0 overflow-hidden">
  <div class="aspect-video bg-bg-2 overflow-hidden relative">
    {t.thumbnail ? (
      <img
        src={t.thumbnail} alt={t.title} loading="lazy"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-4xl">🎓</div>
    )}
    {t.youtubeVideoId && (
      <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/30 transition-colors">
        <div class="w-12 h-12 rounded-pill bg-white/90 flex items-center justify-center">
          <svg class="w-5 h-5 text-bg ml-0.5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
        </div>
      </div>
    )}
  </div>
  <div class="p-5">
    <div class="flex items-center gap-2 mb-2 text-xs text-text-muted">
      {t.category && <span class="badge-accent text-xs">{t.category}</span>}
      {t.difficulty && <span class="badge text-xs bg-bg-2 border border-border">{t.difficulty}</span>}
    </div>
    <h3 class="text-text-white font-bold mb-1 group-hover:text-accent-light transition-colors">{t.title}</h3>
    {excerpt(t.bodyText) && <p class="text-text-muted text-base line-clamp-2">{excerpt(t.bodyText)}</p>}
  </div>
</a>
