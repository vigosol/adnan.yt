---
import { fetchSanity } from '../lib/sanity'
import { SERVICES_LIST_QUERY } from '../lib/queries'
import { normalizeCalLink, getCalNamespace } from '../lib/cal'

interface Props {
  settings?: any
}
const { settings } = Astro.props as Props

const services = await fetchSanity<any[]>(SERVICES_LIST_QUERY).catch(() => [])
const calLink = normalizeCalLink(settings?.calBooking?.calLink)
const calNamespace = getCalNamespace(calLink)

const year = new Date().getFullYear()

const footerCols = [
  {
    title: 'Services',
    links: (services ?? []).slice(0, 5).map((s: any) => ({ href: `/services/${s.slug.current}`, label: s.title })),
  },
  {
    title: 'Company',
    links: [
      { href: '/about', label: 'About' },
      { href: '/portfolio', label: 'Portfolio' },
      { href: '/pricing', label: 'Pricing' },
      { href: '/blog', label: 'Blog' },
      { href: '/tutorials', label: 'Tutorials' },
    ],
  },
]

const iconPaths: Record<string, string> = {
  youtube: 'M23.498 6.186a2.97 2.97 0 0 0-2.088-2.088C19.692 3.5 12 3.5 12 3.5s-7.692 0-9.41.598A2.97 2.97 0 0 0 .502 6.186 31.6 31.6 0 0 0 0 12a31.6 31.6 0 0 0 .502 5.814 2.97 2.97 0 0 0 2.088 2.088C4.308 20.5 12 20.5 12 20.5s7.692 0 9.41-.598a2.97 2.97 0 0 0 2.088-2.088A31.6 31.6 0 0 0 24 12a31.6 31.6 0 0 0-.502-5.814ZM9.75 15.568V8.432L15.818 12 9.75 15.568Z',
  instagram: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069ZM12 0C8.741 0 8.332.014 7.052.072 2.695.272.273 2.69.073 7.052.014 8.332 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.332 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.668-.072-4.948-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0Zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324ZM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881Z',
  tiktok: 'M16.6 5.82s.51.5 0 0A4.278 4.278 0 0 1 15.54 3h-3.09v12.4a2.59 2.59 0 1 1-1.82-2.47V9.4a5.92 5.92 0 1 0 5.07 5.85V8.5a7.5 7.5 0 0 0 4.5 1.5V7.2a4.6 4.6 0 0 1-3.6-1.38Z',
  linkedin: 'M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.56V9h3.56v11.45Z',
  twitter: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.451-6.231Z',
}

const socials = ['youtube', 'instagram', 'tiktok', 'linkedin', 'twitter']
  .filter(key => settings?.socialLinks?.[key])
  .map(key => ({ key, url: settings.socialLinks[key] }))
---

<footer class="bg-[#111827]">
  <div class="container py-16">
    <div class="grid md:grid-cols-[1.5fr_1fr_1fr_1fr] gap-10">
      <div>
        <a href="/" class="inline-flex items-center">
          <img src="/about-logo-dark.svg" alt="adnan.yt" class="h-6 md:h-6.5 w-auto" />
        </a>
        <p class="text-white/60 text-base mt-3 max-w-sm leading-6">
          {settings?.tagline ?? 'Retention-first video editing for YouTube creators, podcasters, coaches, agencies, and brands — turning raw footage into polished, story-driven videos that keep viewers watching till the end.'}
        </p>
      </div>

      {footerCols.map(col => (
        <div>
          <div class="text-white font-semibold text-sm mb-4">{col.title}</div>
          <ul class="space-y-2.5">
            {col.links.map(l => (
              <li><a href={l.href} class="text-white/60 text-sm hover:text-white transition-colors">{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}

      <div>
        <div class="text-white font-semibold text-sm mb-4">Contact</div>
        <ul class="space-y-2.5 text-white/60 text-sm">
          {settings?.email && (
            <li><a href={`mailto:${settings.email}`} class="hover:text-white transition-colors">{settings.email}</a></li>
          )}
          <li>{settings?.footerHours ?? 'Mon–Sat, replies within 24h'}</li>
          <li>{settings?.footerAvailability ?? 'Working worldwide, remotely'}</li>
        </ul>
        <a
          href="/contact"
          {...(calLink ? {
            'data-cal-link': calLink,
            'data-cal-namespace': calNamespace,
            'data-cal-config': '{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}',
          } : {})}
          class="inline-flex items-center gap-1.5 text-accent-light text-sm font-semibold mt-4 hover:underline"
        >
          Book a call →
        </a>
      </div>
    </div>
  </div>

  {socials.length > 0 && (
    <div class="flex items-center justify-center gap-3 pb-10">
      {socials.map(({ key, url }) => (
        <a
          href={url} target="_blank" rel="noopener noreferrer" aria-label={key}
          class="w-11 h-11 flex items-center justify-center rounded-pill bg-accent text-white hover:bg-accent-dark transition-colors"
        >
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d={iconPaths[key]} /></svg>
        </a>
      ))}
    </div>
  )}

  <div class="overflow-hidden">
    <div
      aria-hidden="true"
      class="pointer-events-none select-none text-center font-black leading-none whitespace-nowrap"
      style={
        'font-size: clamp(7rem, 28vw, 20rem); ' +
        'background: linear-gradient(to bottom, rgba(255,255,255,0.18), rgba(255,255,255,0.01) 85%); ' +
        '-webkit-background-clip: text; background-clip: text; color: transparent;'
      }
    >
      adnan
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container py-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/50">
      <p>© {year} adnan.yt. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="/privacy-policy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms-of-service" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
