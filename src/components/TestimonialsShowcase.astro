---
interface Testimonial {
  reviewType?: 'text' | 'video'
  name: string
  company?: string
  role?: string
  quote?: string
  rating?: number
  avatar?: string
  videoUrl?: string
  videoThumbnail?: string
  duration?: string
}
interface Props {
  badge?: string
  heading?: string
  highlightPhrase?: string
  subtitle?: string
  viewAllLabel?: string
  testimonials: Testimonial[]
}
const {
  badge = 'Testimonials',
  heading = 'Creators and brands who trust the process.',
  highlightPhrase = 'trust the process.',
  subtitle,
  viewAllLabel = 'View all Reviews',
  testimonials,
} = Astro.props as Props

// Split the heading around the highlighted phrase so it can render in accent
// color while the rest stays default — natural wrap only, no forced <br>.
function splitHeading(text: string, phrase?: string) {
  if (!phrase) return [{ text, accent: false }]
  const idx = text.indexOf(phrase)
  if (idx === -1) return [{ text, accent: false }]
  return [
    { text: text.slice(0, idx), accent: false },
    { text: text.slice(idx, idx + phrase.length), accent: true },
    { text: text.slice(idx + phrase.length), accent: false },
  ].filter(part => part.text.length > 0)
}
const headingParts = splitHeading(heading, highlightPhrase)

// Each testimonial is explicitly one type or the other (set in Sanity via
// Review Type) — fall back to the presence of a video URL for any older
// records saved before that field existed.
const videoReviews = testimonials.filter(t => t.reviewType === 'video' || (!t.reviewType && t.videoUrl))
const textReviews = testimonials.filter(t => t.reviewType !== 'video' && !(!t.reviewType && t.videoUrl))

// Build fixed-size groups with circular wraparound, so a group that would
// otherwise run short (e.g. 5 items ÷ 3 = groups of [3, 2]) instead wraps
// back to the start to fill the gap — [t1,t2,t3], [t4,t5,t1] — never a
// half-empty slide.
function circularChunks<T>(items: T[], size: number) {
  const total = items.length
  if (total === 0) return []
  const groupCount = Math.ceil(total / size)
  return Array.from({ length: groupCount }, (_, g) =>
    Array.from({ length: size }, (_, j) => items[(g * size + j) % total])
  )
}
const textSlides = circularChunks(textReviews, 3)

function metaLine(t: Testimonial) {
  return [t.role, t.company].filter(Boolean).join(' · ')
}
---

<section>
  <div class="container md:border-x md:border-border-light md:px-0">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 px-6 md:pl-[30px] md:pr-8 py-10 md:py-14">
      <div>
        <span class="inline-block border border-border-light text-text-muted text-xs font-normal uppercase tracking-wide px-3 py-1.5 rounded-full mb-4">{badge}</span>
        <h2 class="text-4xl md:text-5xl font-bold text-text-white tracking-tight max-w-[800px]">
          {headingParts.map(part => part.accent ? <span class="text-accent">{part.text}</span> : part.text)}
        </h2>
        {subtitle && <p class="text-text-muted text-base md:text-lg max-w-xl mt-4">{subtitle}</p>}
      </div>
      <a href="/portfolio" class="group shrink-0 inline-flex items-center gap-2 border-b border-current pb-1 text-text-white font-medium">
        {viewAllLabel}
        <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>

  {videoReviews.length > 0 && (
    <div class="border-t border-border-light">
      <div class="container md:border-x md:border-border-light md:px-0 px-6 md:px-[30px] py-8">
        {videoReviews.length > 4 && (
          <div class="flex items-center justify-end gap-2 mb-4" data-video-scroller>
            <button type="button" data-video-prev aria-label="Previous videos" class="w-9 h-9 rounded-full border border-border text-text-muted flex items-center justify-center hover:bg-bg-2 hover:text-text-white transition-colors cursor-pointer">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </button>
            <button type="button" data-video-next aria-label="Next videos" class="w-9 h-9 rounded-full border border-border text-text-muted flex items-center justify-center hover:bg-bg-2 hover:text-text-white transition-colors cursor-pointer">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </button>
          </div>
        )}
        <div data-video-track class="flex gap-4 md:gap-5 overflow-x-auto scroll-smooth scrollbar-none -mx-6 md:mx-0 px-6 md:px-0">
          {videoReviews.map(t => (
            <a href={t.videoUrl} target="_blank" rel="noopener noreferrer" class="group relative shrink-0 w-[calc((100%-16px)/2)] md:w-[calc((100%-60px)/4)] aspect-[3/4] overflow-hidden bg-bg-2">
              {t.videoThumbnail && (
                <img src={t.videoThumbnail} alt={t.name} loading="lazy" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
              )}

              <div class="absolute inset-0 bg-black/55 group-hover:opacity-0 transition-opacity duration-300"></div>

              {t.duration && (
                <span class="absolute top-3 right-3 z-10 bg-black/70 text-white text-xs px-1.5 py-0.5 rounded">{t.duration}</span>
              )}

              <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <img src="/play-btn.svg" alt="" class="w-14 h-14 drop-shadow-lg" />
              </div>

              <div class="absolute inset-x-0 bottom-0 p-4 opacity-0 translate-y-1 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
                <h3 class="text-white font-semibold text-sm group-hover:text-base group-hover:mb-2 leading-snug transition-all duration-300">{t.name}</h3>
                {metaLine(t) && <p class="text-white/70 text-xs truncate">{metaLine(t)}</p>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  )}

  {textSlides.length > 0 && (
    <div class="border-t border-border-light">
      <div class="container md:border-x md:border-border-light md:px-0">
        <div class="py-8 md:py-10">
          <div data-testimonial-slider>
            <div class="overflow-hidden">
              <div data-track class="flex">
                {textSlides.map(slide => (
                  <div class="w-full shrink-0 grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 md:divide-x divide-border-light">
                    {slide.map(t => (
                      <div class="px-6 md:px-8 py-6">
                        <div class="flex gap-0.5 text-gold mb-3">
                          {Array.from({ length: t.rating ?? 5 }).map(() => (
                            <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1.5l2.6 5.6 6.1.6-4.6 4.1 1.3 6-5.4-3.2-5.4 3.2 1.3-6-4.6-4.1 6.1-.6L10 1.5z" /></svg>
                          ))}
                        </div>
                        {t.quote && <p class="text-text text-base leading-6 mb-4">"{t.quote}"</p>}
                        <div class="flex items-center gap-3">
                          {t.avatar ? (
                            <img src={t.avatar} alt={t.name} class="w-9 h-9 rounded-full object-cover" />
                          ) : (
                            <span class="w-9 h-9 rounded-full bg-bg-2 flex items-center justify-center text-text-white text-sm font-semibold">{t.name.charAt(0)}</span>
                          )}
                          <div>
                            <div class="text-text-white font-semibold text-sm">{t.name}</div>
                            {metaLine(t) && <div class="text-text-muted text-xs">{metaLine(t)}</div>}
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                ))}
              </div>
            </div>

            {textSlides.length > 1 && (
              <div class="flex items-center justify-center gap-4 mt-8 px-6 md:px-8">
                <button type="button" data-prev aria-label="Previous testimonials" class="w-9 h-9 rounded-full border border-border text-text-muted flex items-center justify-center hover:bg-bg-2 hover:text-text-white transition-colors cursor-pointer">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </button>
                <div class="flex gap-2" data-dots>
                  {textSlides.map((_, i) => (
                    <span data-dot class={`w-2 h-2 rounded-full transition-colors ${i === 0 ? 'bg-accent' : 'bg-border-light'}`}></span>
                  ))}
                </div>
                <button type="button" data-next aria-label="Next testimonials" class="w-9 h-9 rounded-full border border-border text-text-muted flex items-center justify-center hover:bg-bg-2 hover:text-text-white transition-colors cursor-pointer">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </button>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  )}
</section>

<script>
  // Seamless infinite loop: clone the first slide and append it. Advancing
  // into the clone looks identical to wrapping to the real first slide, then
  // we snap (no transition) back to the real one once the animation ends —
  // so both next/prev always animate forward/backward, never "rewind".
  function initTestimonialSliders() {
    document.querySelectorAll<HTMLElement>('[data-testimonial-slider]').forEach(slider => {
      const track = slider.querySelector<HTMLElement>('[data-track]')
      const realSlides = track?.children.length ?? 0
      if (!track || realSlides <= 1) return

      track.appendChild(track.children[0].cloneNode(true))
      track.style.transition = 'transform 500ms ease-out'

      const prevBtn = slider.querySelector<HTMLButtonElement>('[data-prev]')
      const nextBtn = slider.querySelector<HTMLButtonElement>('[data-next]')
      const dots = slider.querySelectorAll<HTMLElement>('[data-dot]')

      let pos = 0
      let timer: ReturnType<typeof setInterval> | null = null

      function render(animate: boolean) {
        track!.style.transition = animate ? 'transform 500ms ease-out' : 'none'
        track!.style.transform = `translateX(-${pos * 100}%)`
        const dotIndex = ((pos % realSlides) + realSlides) % realSlides
        dots.forEach((d, i) => {
          d.classList.toggle('bg-accent', i === dotIndex)
          d.classList.toggle('bg-border-light', i !== dotIndex)
        })
      }

      function next() {
        pos += 1
        render(true)
        if (pos === realSlides) {
          track!.addEventListener('transitionend', () => {
            pos = 0
            render(false)
          }, { once: true })
        }
      }

      function prev() {
        if (pos === 0) {
          pos = realSlides
          render(false)
          void track!.offsetWidth
        }
        pos -= 1
        render(true)
      }

      function startAuto() {
        if (timer) clearInterval(timer)
        timer = setInterval(next, 5000)
      }

      nextBtn?.addEventListener('click', () => { next(); startAuto() })
      prevBtn?.addEventListener('click', () => { prev(); startAuto() })

      render(false)
      startAuto()
    })
  }

  function initVideoScrollers() {
    document.querySelectorAll<HTMLElement>('[data-video-scroller]').forEach(controls => {
      const wrapper = controls.parentElement
      const track = wrapper?.querySelector<HTMLElement>('[data-video-track]')
      if (!track) return

      controls.querySelector<HTMLButtonElement>('[data-video-prev]')?.addEventListener('click', () => {
        track.scrollBy({ left: -320, behavior: 'smooth' })
      })
      controls.querySelector<HTMLButtonElement>('[data-video-next]')?.addEventListener('click', () => {
        track.scrollBy({ left: 320, behavior: 'smooth' })
      })
    })
  }

  initTestimonialSliders()
  initVideoScrollers()
</script>
