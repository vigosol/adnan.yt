---
interface NavItem {
  title: string
  slug: { current: string } | string
}
interface Props {
  prev?: NavItem | null
  next?: NavItem | null
  basePath: string
}
const { prev, next, basePath } = Astro.props as Props

function slugOf(item: NavItem) {
  return typeof item.slug === 'string' ? item.slug : item.slug.current
}
---

{(prev || next) && (
  <nav class="flex items-stretch justify-between gap-4 border-t border-b border-border py-6 my-4" aria-label="Post navigation">
    {prev ? (
      <a href={`${basePath}/${slugOf(prev)}`} class="group flex items-center gap-3 min-w-0">
        <svg class="w-5 h-5 shrink-0 text-text-muted transition-transform duration-200 group-hover:-translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M11 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <div class="min-w-0">
          <div class="text-xs text-text-muted uppercase tracking-wide mb-0.5">Previous</div>
          <div class="text-text-white font-semibold truncate group-hover:text-accent-light transition-colors">{prev.title}</div>
        </div>
      </a>
    ) : <span></span>}

    {next ? (
      <a href={`${basePath}/${slugOf(next)}`} class="group flex items-center justify-end gap-3 text-right min-w-0">
        <div class="min-w-0">
          <div class="text-xs text-text-muted uppercase tracking-wide mb-0.5">Next</div>
          <div class="text-text-white font-semibold truncate group-hover:text-accent-light transition-colors">{next.title}</div>
        </div>
        <svg class="w-5 h-5 shrink-0 text-text-muted transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    ) : <span></span>}
  </nav>
)}
