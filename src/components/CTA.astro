---
interface CtaLink {
  label: string
  href: string
}
interface Props {
  badge?: string
  heading: string
  highlightPhrase?: string
  subtext?: string
  primaryCta?: CtaLink
  secondaryCta?: CtaLink
}
const {
  badge,
  heading,
  highlightPhrase,
  subtext,
  primaryCta = { label: 'Get Your Free Quote →', href: '/contact' },
  secondaryCta,
} = Astro.props as Props

// Fixed dark banner — always this color regardless of the light/dark toggle,
// same convention as the red Services/Testimonials sections.
function splitHeading(text: string, phrase?: string) {
  if (!phrase) return [{ text, accent: false }]
  const idx = text.indexOf(phrase)
  if (idx === -1) return [{ text, accent: false }]
  return [
    { text: text.slice(0, idx), accent: false },
    { text: text.slice(idx, idx + phrase.length), accent: true },
    { text: text.slice(idx + phrase.length), accent: false },
  ].filter(part => part.text.length > 0)
}
const headingParts = splitHeading(heading, highlightPhrase)
---

<section class="bg-surface-fixed py-24">
  <div class="container text-center">
    <div class="max-w-2xl mx-auto">
      {badge && (
        <span class="inline-flex items-center gap-1.5 bg-white/10 border border-white/20 text-white text-xs font-normal px-3 py-1.5 rounded-full mb-5">
          <svg class="w-3.5 h-3.5 text-accent-light shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 2c1 3-3 4-3 8a3 3 0 0 0 6 0c0-1-.5-2-1-2.5.5 2 0 3-1 4a4 4 0 0 1-6-3c0-4 4-4 5-9z" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          {badge}
        </span>
      )}
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4 tracking-tight">
        {headingParts.map(part => part.accent ? <span class="text-accent">{part.text}</span> : part.text)}
      </h2>
      {subtext && <p class="text-white/70 mb-8">{subtext}</p>}
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        {primaryCta && (
          primaryCta.href === '/contact' ? (
            <button type="button" data-open-quote-modal class="btn-primary text-base px-8 py-3">{primaryCta.label}</button>
          ) : (
            <a href={primaryCta.href} class="btn-primary text-base px-8 py-3">{primaryCta.label}</a>
          )
        )}
        {secondaryCta && (
          <a href={secondaryCta.href} class="inline-flex items-center justify-center gap-2 border border-white/30 text-white font-semibold text-base px-8 py-3 rounded-btn hover:bg-white/10 transition-colors">
            {secondaryCta.label}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
